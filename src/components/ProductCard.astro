---
interface Props {
  name: string;
  subtitle?: string;
  price?: string;
  rating?: number;
  image: string;
  affiliateLink: string;
  rank?: number;
  verdict?: string;
}

const {
  name,
  subtitle,
  price,
  rating = 5,
  image,
  affiliateLink,
  rank,
  verdict
} = Astro.props;

const stars = "★".repeat(Math.floor(rating)) + "☆".repeat(5 - Math.floor(rating));
---

<div class="product-card">
  <div class="product-grid">
    <div class="product-image-wrap">
      {rank && <span class="product-rank">#{rank} {subtitle && `- ${subtitle}`}</span>}
      <img src={image} alt={name} loading="lazy" />
    </div>

    <div class="product-info">
      <h3>{name}</h3>
      {price && <p class="product-price"><strong>Faixa de Preço:</strong> {price}</p>}
      
      <div class="product-rating">
        <span class="stars">{stars}</span>
        <span class="rating-text">{rating.toFixed(1)} Avaliação A Pan</span>
      </div>
      
      {verdict && (
        <p class="product-verdict">
          <em>Veredicto: "{verdict}"</em>
        </p>
      )}

      <div class="product-actions">
        <a href={affiliateLink} target="_blank" rel="nofollow noopener" class="btn-primary">
          VER PREÇO NA AMAZON
        </a>
      </div>
    </div>
  </div>
  <slot />
</div>

<style>
  .product-card {
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 32px;
    margin: 40px 0;
    background: #fff;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  }

  .product-grid {
    display: flex;
    gap: 32px;
    align-items: center;
  }

  .product-image-wrap {
    width: 220px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .product-rank {
    background: #1f2937;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .product-image-wrap img {
    width: 100%;
    height: 200px;
    object-fit: contain;
  }

  .product-info { flex: 1; }

  h3 {
    font-size: 1.5rem;
    font-weight: 800;
    color: #111;
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .product-price {
    font-size: 1rem;
    color: #6b7280;
    margin-bottom: 16px;
  }

  .product-rating {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  .stars { color: #f59e0b; font-size: 1.2rem; }
  .rating-text { font-size: 0.9rem; color: #6b7280; font-weight: 500; }

  .product-verdict {
    background: #f9fafb;
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 0.95rem;
    margin-bottom: 20px;
    color: #374151;
  }

  .btn-primary {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    background: #e31e24;
    color: #fff;
    padding: 14px 24px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1rem;
    transition: all 0.2s;
    box-shadow: 0 2px 4px rgba(227, 30, 36, 0.2);
  }

  .btn-primary:hover {
    background: #c41a1f;
    transform: translateY(-2px);
    box-shadow: 0 4px 6px rgba(227, 30, 36, 0.3);
    color: #fff;
  }

  @media (max-width: 900px) {
    .product-grid { flex-direction: column; }
    .product-image-wrap { width: 100%; }
    .product-card { padding: 24px; }
  }
</style>
