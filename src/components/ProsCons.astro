---
interface Props {
  pros: string[];
  cons: string[];
  titlePros?: string;
  titleCons?: string;
}

const { 
  pros, 
  cons, 
  titlePros = "Vantagens e Specs", 
  titleCons = "Pontos de Atenção" 
} = Astro.props;
---

<div class="pros-cons-container">
  <div class="pros-box">
    <h4><span>👍</span> {titlePros}</h4>
    <ul>
      {pros.map(item => <li>{item}</li>)}
    </ul>
  </div>
  <div class="cons-box">
    <h4><span>👎</span> {titleCons}</h4>
    <ul>
      {cons.map(item => <li>{item}</li>)}
    </ul>
  </div>
</div>

<style>
  .pros-cons-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin: 32px 0;
  }

  .pros-box, .cons-box {
    padding: 24px;
    border-radius: 16px;
    border: 1px solid #e5e7eb;
  }

  .pros-box { background: #f0fdf4; border-color: #dcfce7; }
  .cons-box { background: #fef2f2; border-color: #fee2e2; }

  h4 {
    margin: 0 0 16px;
    font-size: 1.05rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .pros-box h4 { color: #16a34a; }
  .cons-box h4 { color: #dc2626; }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 12px;
    padding-left: 24px;
    position: relative;
    color: #374151;
  }

  .pros-box li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #16a34a;
    font-weight: 900;
  }

  .cons-box li::before {
    content: "✕";
    position: absolute;
    left: 0;
    color: #dc2626;
    font-weight: 900;
  }

  @media (max-width: 768px) {
    .pros-cons-container {
      grid-template-columns: 1fr;
    }
  }
</style>
