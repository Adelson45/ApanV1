---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Como Prender o Capacete Corretamente: Guia Passo a Passo';
const description = 'Aprenda o jeito certo de prender o capacete na moto. Fechos engate rápido, double D e microrregulagem — saiba qual escolher e como ajustar com segurança.';
const canonical = 'https://jovemapan.com.br/como-prender-o-capacete/';
const author = 'Marcelo Ferreira';
const authorImage = '/images/marcelo-ferreira.png';
const publishDate = '2026-04-23';
const category = 'Dicas';
const categoryHref = '/category/dicas/';
const coverImage = '/images/moto-shop-cover.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. Tipos de fecho', href: '#tipos-fecho' },
  { label: '3. Passo a passo para prender', href: '#passo-a-passo' },
  { label: '4. Erros mais comuns', href: '#erros' },
  { label: '5. Conclusão', href: '#conclusao' },
];

const tags = [
  { label: 'DICAS', href: '/category/dicas/' },
  { label: 'SEGURANÇA', href: '#' },
  { label: 'CAPACETE', href: '/melhor-capacete/' },
  { label: '2026', href: '#' },
];

const featuredProduct = {
  preTitle: 'APROVEITE FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete Shoei Premium Edition',
  name: 'Capacete Shoei<br/>Premium Edition',
  mercadoLivreHref: '#',
  amazonHref: '#',
};

const authorBio = {
  name: author,
  description: 'Redator & Editor especializado em transformar especificações técnicas complexas em conteúdo claro, envolvente e acessível.',
  image: authorImage,
  profileHref: '/author-marcelo-ferreira/',
  profileLabel: 'Ver perfil completo ›',
};
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  authorImage={authorImage}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  featuredProduct={featuredProduct}
>
  <p class="post-lead" id="introducao">
    Conteúdo do post em breve.
  </p>

  <h2 id="tipos-fecho">Tipos de fecho</h2>
  <p>Em breve.</p>

  <h2 id="passo-a-passo">Passo a passo para prender</h2>
  <p>Em breve.</p>

  <h2 id="erros">Erros mais comuns</h2>
  <p>Em breve.</p>

  <h2 id="conclusao">Conclusão</h2>
  <p>Em breve.</p>
</PostLayout>
