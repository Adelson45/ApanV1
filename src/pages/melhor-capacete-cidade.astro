---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Melhor Capacete Para Andar na Cidade: Guia Completo 2026';
const description = 'Guia completo dos melhores capacetes para uso urbano em 2026. Conforto, segurança e custo-benefício para o dia a dia na cidade.';
const canonical = 'https://jovemapan.com.br/melhor-capacete-cidade/';
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  category="Reviews"
  categoryHref="/category/reviews/"
  publishDate="2026-01-01"
  author="Pamela Pan"
>
  <h2>Conteúdo em breve</h2>
  <p>Este post está sendo preparado. Em breve traremos a análise completa.</p>
</PostLayout>
