---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Capacete Peels é Bom? Análise Completa 2026 | Review dos Modelos';
const description = 'Review completo dos capacetes Peels. Análise dos modelos aberto, fechado e articulado. Preço, qualidade, segurança e vale a pena comprar? Descubra agora!';

const models = [
  {
    name: 'Peels Icon',
    type: 'Fechado (Integral)',
    price: 'R$ 350 - R$ 480',
    rating: 4.4,
    image: '/images/peels-icon.jpg',
    features: [
      'Casco ABS de alta resistência',
      'Certificação INMETRO e ECE 22.05',
      'Viseira policarbonato anti-risco',
      'Sistema de ventilação com 4 entradas',
      'Forro removível e lavável',
      'Peso: 1.450g'
    ],
    verdict: 'Excelente custo-benefício para iniciantes e uso urbano diário.'
  },
  {
    name: 'Peels Freeway',
    type: 'Aberto (3/4)',
    price: 'R$ 220 - R$ 320',
    rating: 4.2,
    image: '/images/peels-freeway.jpg',
    features: [
      'Casco ABS leve',
      'Certificação INMETRO',
      'Viseira curta inclusa',
      'Óculos de sol interno',
      'Forro confortável',
      'Peso: 1.100g'
    ],
    verdict: 'Ótima opção para trânsito urbano leve e curtas distâncias.'
  },
  {
    name: 'Peels Mirage',
    type: 'Articulado (Robocop)',
    price: 'R$ 480 - R$ 650',
    rating: 4.3,
    image: '/images/peels-mirage.jpg',
    features: [
      'Mecanismo de articulação reforçado',
      'Certificação INMETRO e ECE 22.05',
      'Dupla viseira (transparente + fumê)',
      'Forro premium com maior conforto',
      'Sistema de ventilação avançado',
      'Peso: 1.650g'
    ],
    verdict: 'Versatilidade máxima para quem precisa de aberto e fechado.'
  }
];

const pros = [
  'Preço acessível para todas as categorias',
  'Marca nacional com garantia e suporte',
  'Certificações INMETRO em todos os modelos',
  'Boa disponibilidade de peças de reposição',
  'Design moderno e variadas cores',
  'Ótimo para iniciantes no mundo das motos'
];

const cons = [
  'Acabamento inferior a marcas premium (Arai, Shoei)',
  'Ventilação limitada em alguns modelos',
  'Viseira sem tratamento anti-embaçante premium',
  'Isolamento acústico básico',
  'Conforto em viagens longas (>2h)',
  'Durabilidade do mecanismo em modelos articulados'
];

const comparisonTable = [
  { aspect: 'Preço', peels: '★★★★★', premium: '★★☆☆☆' },
  { aspect: 'Segurança', peels: '★★★★☆', premium: '★★★★★' },
  { aspect: 'Conforto', peels: '★★★☆☆', premium: '★★★★★' },
  { aspect: 'Acabamento', peels: '★★★☆☆', premium: '★★★★★' },
  { aspect: 'Ventilação', peels: '★★★☆☆', premium: '★★★★★' },
  { aspect: 'Durabilidade', peels: '★★★☆☆', premium: '★★★★★' }
];
---

<Layout title={title} description={description}>
  <Header />
  
  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <h1>Capacete Peels é Bom?</h1>
        <p class="hero-subtitle">
          Análise completa da marca nacional Peels. Review dos modelos Icon, Freeway e Mirage 
          com preços, qualidade e nossa opinião sincera.
        </p>
        <div class="hero-verdict">
          <span class="verdict-badge">Veredito: Bom</span>
          <p>Excelente custo-benefício para uso urbano</p>
        </div>
      </div>
    </section>

    <!-- Summary -->
    <section class="summary-section">
      <div class="container">
        <div class="summary-box">
          <h2>Resumo da Análise</h2>
          <p>
            A <strong>Peels</strong> é uma marca brasileira que oferece capacetes com <strong>certificação INMETRO</strong> a preços 
            muito competitivos. Seus produtos são indicados para iniciantes, uso urbano e quem busca 
            um segundo capacete sem gastar muito.
          </p>
          <p>
            <strong>Não espere acabamento premium</strong>, mas para o preço cobrado, a Peels entrega 
            segurança certificada e design moderno. É uma escolha inteligente para quem está começando 
            ou usa a moto apenas para deslocamentos urbanos.
          </p>
          <div class="rating-summary">
            <div class="rating-item">
              <span class="rating-number">4.4</span>
              <span class="rating-label">Nota Geral</span>
            </div>
            <div class="rating-item">
              <span class="rating-stars">★★★★☆</span>
              <span class="rating-label">Custo-Benefício</span>
            </div>
            <div class="rating-item">
              <span class="rating-recommend">85%</span>
              <span class="rating-label">Recomendam</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Models Section -->
    <section class="models-section">
      <div class="container">
        <h2>Modelos Analisados</h2>
        <div class="models-grid">
          {models.map((model, index) => (
            <article class="model-card">
              <div class="model-header">
                <span class="model-type">{model.type}</span>
                <span class="model-rating">★ {model.rating}</span>
              </div>
              <div class="model-image">
                <img src={model.image} alt={model.name} loading="lazy" />
              </div>
              <div class="model-content">
                <h3>{model.name}</h3>
                <p class="model-price">{model.price}</p>
                <div class="model-features">
                  <h4>Principais Características</h4>
                  <ul>
                    {model.features.map(feature => (
                      <li>{feature}</li>
                    ))}
                  </ul>
                </div>
                <div class="model-verdict">
                  <strong>Nossa opinião:</strong> {model.verdict}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Pros and Cons -->
    <section class="pros-cons-section">
      <div class="container">
        <div class="pros-cons-grid">
          <div class="pros-box">
            <h3>✓ Pontos Positivos</h3>
            <ul>
              {pros.map(pro => (
                <li>{pro}</li>
              ))}
            </ul>
          </div>
          <div class="cons-box">
            <h3>✗ Pontos Negativos</h3>
            <ul>
              {cons.map(con => (
                <li>{con}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Comparison -->
    <section class="comparison-section">
      <div class="container">
        <h2>Peels vs Marcas Premium</h2>
        <div class="comparison-table-wrapper">
          <table class="comparison-table">
            <thead>
              <tr>
                <th>Aspecto</th>
                <th>Peels</th>
                <th>Marcas Premium (Arai, Shoei, AGV)</th>
              </tr>
            </thead>
            <tbody>
              {comparisonTable.map(row => (
                <tr>
                  <td><strong>{row.aspect}</strong></td>
                  <td>{row.peels}</td>
                  <td>{row.premium}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="comparison-note">
          <strong>Nota:</strong> Marcas premium (Arai, Shoei, AGV) custam 5x a 10x mais que a Peels. 
          A comparação deve considerar a diferença de preço.
        </p>
      </div>
    </section>

    <!-- Final Verdict -->
    <section class="final-verdict-section">
      <div class="container">
        <div class="verdict-box">
          <h2>Vale a Pena Comprar?</h2>
          <div class="verdict-content">
            <div class="verdict-recommend">
              <span class="recommend-badge">👍 Recomendado</span>
              <p class="recommend-for">
                <strong>Para quem é ideal:</strong>
              </p>
              <ul>
                <li>Iniciantes no mundo das motos</li>
                <li>Uso urbano diário (até 60km/h)</li>
                <li>Segundo capacete de reserva</li>
                <li>Quem busca custo-benefício</li>
                <li>Orçamento limitado</li>
              </ul>
            </div>
            <div class="verdict-not-recommend">
              <span class="not-recommend-badge">👎 Não Recomendado</span>
              <p class="not-recommend-for">
                <strong>Não compre se:</strong>
              </p>
              <ul>
                <li>Você faz viagens longas frequentes</li>
                <li>Pilota em estradas em alta velocidade</li>
                <li>Busca máxima qualidade e durabilidade</li>
                <li>Tem orçamento para marcas premium</li>
              </ul>
            </div>
          </div>
          <div class="final-cta">
            <p class="final-opinion">
              <strong>Nossa opinião final:</strong> A Peels é uma excelente porta de entrada para quem 
              busca segurança certificada sem gastar muito. Para uso urbano, entrega tudo que você precisa. 
              Para viagens longas, considere investir em algo melhor.
            </p>
            <a href="https://amzn.to/peelsicon" target="_blank" rel="nofollow noopener" class="btn btn-primary">
              Ver Preços dos Modelos Peels
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Related Reviews -->
    <section class="related-section">
      <div class="container">
        <h2>Reviews Relacionadas</h2>
        <div class="related-grid">
          <a href="/capacete-norisk-review/" class="related-card">
            <h3>Review Norisk</h3>
            <p>Concorrente direto da Peels</p>
          </a>
          <a href="/ls2-scope-monocolor-review/" class="related-card">
            <h3>Review LS2</h3>
            <p>Opção intermediária de qualidade</p>
          </a>
          <a href="/custo-beneficio/" class="related-card">
            <h3>Custo Benefício</h3>
            <p>Veja todas as opções acessíveis</p>
          </a>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, #e31b1b 0%, #b71c1c 100%);
    color: #fff;
    padding: 80px 20px;
    text-align: center;
  }
  
  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 20px;
  }
  
  .hero-subtitle {
    font-size: 1.2rem;
    max-width: 700px;
    margin: 0 auto 30px;
    opacity: 0.9;
  }
  
  .hero-verdict {
    display: inline-block;
    background: rgba(255,255,255,0.2);
    padding: 20px 40px;
    border-radius: 8px;
    backdrop-filter: blur(10px);
  }
  
  .verdict-badge {
    display: block;
    font-size: 1.5rem;
    font-weight: bold;
    margin-bottom: 10px;
  }
  
  .hero-verdict p {
    margin: 0;
    opacity: 0.9;
  }
  
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  
  .summary-section, .models-section, .pros-cons-section, .comparison-section, .final-verdict-section, .related-section {
    padding: 60px 20px;
  }
  
  .summary-section {
    background: #f5f5f5;
  }
  
  .summary-box {
    background: #fff;
    border-radius: 8px;
    padding: 40px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  
  .summary-box h2 {
    text-align: center;
    margin-bottom: 25px;
  }
  
  .summary-box p {
    line-height: 1.7;
    color: #555;
    margin-bottom: 15px;
  }
  
  .rating-summary {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin-top: 30px;
    padding-top: 30px;
    border-top: 1px solid #eee;
  }
  
  .rating-item {
    text-align: center;
  }
  
  .rating-number {
    display: block;
    font-size: 2.5rem;
    font-weight: bold;
    color: #e31b1b;
  }
  
  .rating-stars {
    display: block;
    font-size: 1.8rem;
    color: #FFD700;
  }
  
  .rating-recommend {
    display: block;
    font-size: 2rem;
    font-weight: bold;
    color: #4CAF50;
  }
  
  .rating-label {
    display: block;
    font-size: 0.9rem;
    color: #666;
    margin-top: 5px;
  }
  
  h2 {
    text-align: center;
    font-size: 2rem;
    margin-bottom: 40px;
  }
  
  .models-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 30px;
  }
  
  .model-card {
    background: #fff;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    overflow: hidden;
  }
  
  .model-header {
    background: #212121;
    color: #fff;
    padding: 15px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .model-type {
    font-size: 0.85rem;
    text-transform: uppercase;
    opacity: 0.9;
  }
  
  .model-rating {
    color: #FFD700;
    font-weight: bold;
  }
  
  .model-image {
    height: 200px;
    overflow: hidden;
  }
  
  .model-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .model-content {
    padding: 25px;
  }
  
  .model-content h3 {
    font-size: 1.4rem;
    margin-bottom: 5px;
  }
  
  .model-price {
    font-size: 1.2rem;
    color: #4CAF50;
    font-weight: bold;
    margin-bottom: 20px;
  }
  
  .model-features h4 {
    font-size: 1rem;
    margin-bottom: 12px;
    color: #333;
  }
  
  .model-features ul {
    list-style: none;
    padding: 0;
    margin-bottom: 20px;
  }
  
  .model-features li {
    padding: 6px 0;
    padding-left: 20px;
    position: relative;
    font-size: 0.9rem;
    color: #555;
    border-bottom: 1px solid #f0f0f0;
  }
  
  .model-features li::before {
    content: "▸";
    position: absolute;
    left: 0;
    color: #e31b1b;
  }
  
  .model-verdict {
    background: #e3f2fd;
    padding: 15px;
    border-radius: 4px;
    border-left: 4px solid #2196F3;
  }
  
  .pros-cons-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
  }
  
  .pros-box, .cons-box {
    padding: 30px;
    border-radius: 8px;
  }
  
  .pros-box {
    background: #e8f5e9;
  }
  
  .cons-box {
    background: #ffebee;
  }
  
  .pros-box h3 {
    color: #2e7d32;
    margin-bottom: 20px;
    font-size: 1.3rem;
  }
  
  .cons-box h3 {
    color: #c62828;
    margin-bottom: 20px;
    font-size: 1.3rem;
  }
  
  .pros-box ul, .cons-box ul {
    list-style: none;
    padding: 0;
  }
  
  .pros-box li, .cons-box li {
    padding: 10px 0;
    padding-left: 25px;
    position: relative;
    line-height: 1.5;
  }
  
  .pros-box li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #2e7d32;
    font-weight: bold;
  }
  
  .cons-box li::before {
    content: "×";
    position: absolute;
    left: 0;
    color: #c62828;
    font-weight: bold;
  }
  
  .comparison-table-wrapper {
    overflow-x: auto;
  }
  
  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 20px;
  }
  
  .comparison-table th,
  .comparison-table td {
    padding: 15px;
    text-align: left;
    border-bottom: 1px solid #ddd;
  }
  
  .comparison-table th {
    background: #212121;
    color: #fff;
    font-weight: 600;
  }
  
  .comparison-table tr:hover {
    background: #f5f5f5;
  }
  
  .comparison-note {
    text-align: center;
    margin-top: 20px;
    color: #666;
    font-style: italic;
  }
  
  .final-verdict-section {
    background: #f5f5f5;
  }
  
  .verdict-box {
    background: #fff;
    border-radius: 8px;
    padding: 40px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  
  .verdict-box h2 {
    margin-bottom: 30px;
  }
  
  .verdict-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-bottom: 30px;
  }
  
  .verdict-recommend {
    background: #e8f5e9;
    padding: 25px;
    border-radius: 8px;
  }
  
  .verdict-not-recommend {
    background: #ffebee;
    padding: 25px;
    border-radius: 8px;
  }
  
  .recommend-badge {
    display: block;
    font-size: 1.3rem;
    font-weight: bold;
    color: #2e7d32;
    margin-bottom: 15px;
  }
  
  .not-recommend-badge {
    display: block;
    font-size: 1.3rem;
    font-weight: bold;
    color: #c62828;
    margin-bottom: 15px;
  }
  
  .verdict-content ul {
    list-style: none;
    padding: 0;
  }
  
  .verdict-content li {
    padding: 8px 0;
    padding-left: 20px;
    position: relative;
    color: #555;
  }
  
  .verdict-content li::before {
    content: "•";
    position: absolute;
    left: 0;
    font-weight: bold;
  }
  
  .final-cta {
    background: #fff3cd;
    padding: 25px;
    border-radius: 8px;
    border-left: 4px solid #ffc107;
    text-align: center;
  }
  
  .final-opinion {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #555;
    margin-bottom: 20px;
  }
  
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
  }
  
  .related-card {
    background: #212121;
    color: #fff;
    padding: 25px;
    border-radius: 8px;
    text-decoration: none;
    text-align: center;
    transition: transform 0.3s ease;
  }
  
  .related-card:hover {
    transform: translateY(-5px);
    background: #e31b1b;
  }
  
  .related-card h3 {
    margin-bottom: 8px;
  }
  
  .related-card p {
    opacity: 0.9;
    font-size: 0.9rem;
  }
  
  .btn {
    display: inline-block;
    padding: 15px 30px;
    background: #e31b1b;
    color: #fff;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: background 0.3s ease;
  }
  
  .btn:hover {
    background: #c41717;
  }
  
  @media (max-width: 768px) {
    .pros-cons-grid,
    .verdict-content {
      grid-template-columns: 1fr;
    }
    
    .rating-summary {
      flex-direction: column;
      gap: 20px;
    }
    
    .hero-verdict {
      padding: 15px 25px;
    }
    
    .verdict-badge {
      font-size: 1.2rem;
    }
  }
</style>
