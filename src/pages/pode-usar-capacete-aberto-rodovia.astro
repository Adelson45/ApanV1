---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Pode Usar Capacete Aberto em Rodovia? Saiba o Que Diz a Lei';
const description = 'Capacete aberto em rodovia é permitido? Entenda a legislação brasileira, os riscos envolvidos e quando esse tipo de capacete realmente faz sentido.';
const canonical = 'https://jovemapan.com.br/pode-usar-capacete-aberto-rodovia/';
const author = 'Marcelo Ferreira';
const authorImage = '/images/marcelo-ferreira.png';
const publishDate = '2026-04-23';
const category = 'Legislação';
const categoryHref = '/capacete-aberto/';
const coverImage = '/images/moto-shop-cover.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. O que é um capacete aberto', href: '#o-que-e' },
  { label: '3. O que diz a lei', href: '#lei' },
  { label: '4. Riscos em rodovia', href: '#riscos' },
  { label: '5. Conclusão', href: '#conclusao' },
];

const tags = [
  { label: 'LEGISLAÇÃO', href: '#' },
  { label: 'CAPACETE ABERTO', href: '/capacete-aberto/' },
  { label: 'RODOVIA', href: '#' },
  { label: '2026', href: '#' },
];

const featuredProduct = {
  preTitle: 'APROVEITE FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete Shoei Premium Edition',
  name: 'Capacete Shoei<br/>Premium Edition',
  mercadoLivreHref: '#',
  amazonHref: '#',
};

const authorBio = {
  name: author,
  description: 'Redator & Editor especializado em transformar especificações técnicas complexas em conteúdo claro, envolvente e acessível.',
  image: authorImage,
  profileHref: '/author-marcelo-ferreira/',
  profileLabel: 'Ver perfil completo ›',
};
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  authorImage={authorImage}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  featuredProduct={featuredProduct}
>
  <p class="post-lead" id="introducao">
    Conteúdo do post em breve.
  </p>

  <h2 id="o-que-e">O que é um capacete aberto</h2>
  <p>Em breve.</p>

  <h2 id="lei">O que diz a lei</h2>
  <p>Em breve.</p>

  <h2 id="riscos">Riscos em rodovia</h2>
  <p>Em breve.</p>

  <h2 id="conclusao">Conclusão</h2>
  <p>Em breve.</p>
</PostLayout>
