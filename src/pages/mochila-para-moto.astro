    <div class="btn-buy-container">
      <a href="https://amzn.to/4nNM1w4" class="btn-buy" target="_blank" rel="nofollow noopener noreferrer">Ver na Amazon</a>
      <a href="https://mercadolivre.com/sec/2HzkjqW" class="btn-buy ml" target="_blank" rel="nofollow noopener noreferrer">Ver no Mercado Livre</a>
