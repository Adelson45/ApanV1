const title = 'Capacete Aberto é Bom? Guia Completo: Prós, Contras, Segurança e Legislação';
const description = 'Tudo sobre o capacete aberto: suas vantagens e desvantagens, quando e onde usá-lo com segurança, o que a lei diz e dicas essenciais. Tome a melhor decisão.';
