---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Capacete Aberto 2026 | Melhores Modelos de 3/4 com Análises';
const description = 'Descubra os melhores capacetes abertos (3/4) de 2026. Análises completas, prós e contras, e dicas para escolher o modelo ideal para uso urbano.';
const canonical   = 'https://jovemapan.com.br/capacete-aberto/';
const author      = 'Marcelo Ferreira';
const publishDate = '20 ABR, 2026';
const category    = 'CAPACETES';
const categoryHref = '/melhor-capacete/';
const coverImage  = '/images/piloto-com-sua-moro-branca.png';
---

<Layout title={title} description={description} canonical={canonical}>
  <style>
    .info-card-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      align-items: center;
      background: #f8f9fa;
      border-radius: 8px;
      padding: 15px;
      margin: 20px 0;
    }
    .info-card-image img {
      width: 100%;
      height: auto;
      border-radius: 4px;
    }
    .info-card-content h4 {
      margin: 0 0 10px 0;
      font-size: 1.1rem;
    }
    .info-card-content h4 a {
      color: #0066cc;
      text-decoration: underline;
    }
    .info-card-content p {
      margin: 0;
      color: #555;
      font-size: 0.95rem;
    }
    @media (max-width: 768px) {
      .info-card-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
  <Header />

  <main class="post-main">
    <div class="post-container">

      <!-- ==========================================
           1. CABEÇALHO (Breadcrumb, Título, Info)
           ========================================== -->
      <div class="post-header-section">
        <nav class="top-breadcrumb" aria-label="Breadcrumb">
          <a href="/">HOME</a>
          <span class="separator">›</span>
          <a href={categoryHref}>{category}</a>
          <span class="separator">›</span>
          <span class="current-page">Capacete Aberto 2026</span>
        </nav>

        <a href={categoryHref} class="post-category-tag">
          <svg class="icon" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
          {category}
        </a>

        <h1 class="post-title">Capacete Aberto 2026 | Melhores Modelos de 3/4</h1>

        <div class="post-meta-data">
          <div class="meta-author">
            <img src="/images/marcelo-ferreira.png" alt={author} class="author-avatar" onerror="this.src='https://ui-avatars.com/api/?name=Marcelo+Ferreira&background=random'" />
            <strong>{author.toUpperCase()}</strong>
          </div>
          <div class="meta-info">
             <span class="meta-item">
               <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
               {publishDate}
             </span>
             <span class="meta-item">
               <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
               32K VIEWS
             </span>
             <span class="meta-item">
               <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
               8 COMMENTS
             </span>
          </div>
        </div>
      </div>

      <!-- ==========================================
           2. GRID PRINCIPAL (Col 1: Social | Col 2: Artigo | Col 3: Sidebar)
           ========================================== -->
      <div class="post-layout-grid">
        
        <!-- [ESQUERDA] Botões Sociais -->
        <div class="post-social-col">
          <div class="sticky-socials">
            <a href="https://www.facebook.com/profile.php?id=100088166945491" target="_blank" rel="noopener noreferrer" class="social-btn facebook" aria-label="Facebook">f</a>
            <a href="https://br.pinterest.com/jovemapan/" target="_blank" rel="noopener noreferrer" class="social-btn pinterest" aria-label="Pinterest">
              <svg viewBox="0 0 24 24" fill="white" width="18" height="18"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
            </a>
            <a href="https://www.youtube.com/channel/UCChj9-uIY5ERfidZ6K-zt_w" target="_blank" rel="noopener noreferrer" class="social-btn youtube" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="white" width="18" height="18"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
            <a href="https://www.instagram.com/jovem_apan/" target="_blank" rel="noopener noreferrer" class="social-btn instagram" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" width="18" height="18"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
          </div>
        </div>

        <!-- [CENTRO] Artigo -->
        <article class="post-content-col">
          
          <!-- Foto de Capa (Hero) com Selo Verified -->
          <div class="post-cover-image">
            <img src={coverImage} alt="Capa do Artigo" />
            <div class="verified-badge">
              <svg viewBox="0 0 24 24" width="12" height="12" stroke="var(--red)" stroke-width="3" fill="none"><polyline points="20 6 9 17 4 12"></polyline></svg>
              APAN VERIFIED
            </div>
          </div>

          <!-- Índice Modo Accordion -->
          <div class="post-indice" id="indice-accordion">
            <div class="indice-header" onclick="toggleIndice()">
              <div class="indice-left">
                <div class="indice-icon">
                  <svg viewBox="0 0 24 24" width="18" height="18" stroke="white" stroke-width="2" fill="none"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
                </div>
                <strong>ÍNDICE DE CONTEÚDO</strong>
              </div>
              <div class="indice-arrow" id="indice-arrow">
                <svg viewBox="0 0 24 24" width="16" height="16" stroke="var(--text-meta)" stroke-width="2" fill="none"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </div>
            </div>
            <div class="indice-content" id="indice-content">
              <ul class="indice-links">
                <li><a href="#introducao">Introdução</a></li>
                <li><a href="#vantagens">Vantagens do Capacete Aberto</a></li>
                <li><a href="#desvantagens">Desvantagens do Capacete Aberto</a></li>
                <li><a href="#quando-usar">Quando Usar</a></li>
                <li><a href="#melhores">Melhores Capacetes Abertos de 2026</a>
                  <ul>
                    <li><a href="#norisk-darth">1. Capacete Norisk Darth</a></li>
                    <li><a href="#ls2-of562">2. Capacete LS2 OF562 Airflow</a></li>
                    <li><a href="#arai-szr">3. Capacete Arai SZ-R Vas</a></li>
                    <li><a href="#agv-orbyt">4. Capacete AGV Orbyt Block</a></li>
                  </ul>
                </li>
                <li><a href="#comparativo">Capacete Aberto vs Fechado</a></li>
                <li><a href="#seguranca">Importante: Segurança</a></li>
                <li><a href="#conclusao">Conclusão</a></li>
              </ul>
            </div>
          </div>

          <!-- CONTEÚDO DO ARTIGO -->
          <p class="post-lead" id="introducao">Descubra os melhores capacetes abertos (3/4) de 2026. Análises completas, prós e contras, e dicas para escolher o modelo ideal para uso urbano. Os capacetes abertos oferecem maior visibilidade, ventilação natural e praticidade para o dia a dia.</p>

          <p>Capacetes abertos, também conhecidos como capacetes 3/4, são a escolha perfeita para motociclistas urbanos que buscam conforto, ventilação e praticidade. Eles deixam o rosto exposto, proporcionando maior campo de visão e facilidade de comunicação.</p>

          <h2 id="vantagens">Vantagens do Capacete Aberto</h2>
          <ul>
            <li><strong>Leveza</strong> - Menor peso que capacetes integrais, reduzindo fadiga no pescoço</li>
            <li><strong>Ventilação natural</strong> - Fluxo de ar constante mantém o piloto fresco</li>
            <li><strong>Campo de visão ampliado</strong> - Maior percepção do ambiente ao redor</li>
            <li><strong>Facilidade de comunicação</strong> - Fale sem remover o capacete</li>
            <li><strong>Conforto em calor</strong> - Ideal para climas quentes</li>
            <li><strong>Praticidade</strong> - Fácil de colocar e retirar</li>
          </ul>

          <h2 id="desvantagens">Desvantagens do Capacete Aberto</h2>
          <ul>
            <li><strong>Menor proteção</strong> - Não protege o queixo e parte do rosto em impactos</li>
            <li><strong>Exposição às intempéries</strong> - Chuva, vento e sol diretamente no rosto</li>
            <li><strong>Ruído do vento</strong> - Maior exposição ao barulho em velocidades elevadas</li>
            <li><strong>Não indicado para alta velocidade</strong> - Limite recomendado de 60km/h</li>
            <li><strong>Lesões faciais</strong> - Risco maior em caso de acidentes graves</li>
          </ul>

          <h2 id="quando-usar">Quando Usar um Capacete Aberto</h2>
          <p>Perfeito para trânsito urbano, velocidades até 60km/h, e climas quentes. Não recomendado para estradas ou velocidades elevadas. Considere usar óculos de proteção ou viseira adicional.</p>

          <h2 id="melhores">Melhores Capacetes Abertos de 2026</h2>
          <p>Separamos os melhores capacetes abertos de 2026, de acordo com as nossas avaliações. Fique de olho, pois vamos atualizar essa lista sempre que testarmos novos modelos.</p>

          <!-- NORISK DARTH -->
          <div class="product-section" id="norisk-darth">
            <h3>1. Capacete Norisk Darth Open</h3>
            <div class="h2-image-card product-image">
              <img src="/images/norisk-darth.jpg" alt="Capacete Norisk Darth" />
            </div>
            <p>O Norisk Darth Open é um capacete aberto moderno com design agressivo e excelente custo-benefício para uso urbano. Com casco em termoplástico de alta resistência, viseira 2D anti-risco e sistema de ventilação superior.</p>
            <p><strong>Preço:</strong> R$ 280 - R$ 380 | <strong>Peso:</strong> 1.100g | <strong>Certificação:</strong> Inmetro</p>
            <p><a href="https://amzn.to/noriskdarth" class="btn-buy" target="_blank" rel="noopener noreferrer">Ver na Amazon</a></p>
            
            <div class="pros-cons-grid">
              <div class="pc-col">
                <h4 class="pros">PRÓS</h4>
                <ul class="pc-list pros">
                  <li>Preço acessível</li>
                  <li>Design moderno e jovial</li>
                  <li>Leveza para trânsito urbano</li>
                  <li>Boa ventilação natural</li>
                </ul>
              </div>
              <div class="pc-col">
                <h4 class="cons">CONTRAS</h4>
                <ul class="pc-list cons">
                  <li>Proteção inferior ao capacete fechado</li>
                  <li>Ruído em velocidades elevadas</li>
                  <li>Sem viseira solar</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- LS2 OF562 -->
          <div class="product-section" id="ls2-of562">
            <h3>2. Capacete LS2 OF562 Airflow</h3>
            <div class="h2-image-card product-image">
              <img src="/images/ls2-of562.jpg" alt="Capacete LS2 OF562" />
            </div>
            <p>O LS2 OF562 Airflow é referência em capacetes abertos, com excelente ventilação e acabamento superior na categoria. Casco de ABS de alta resistência com múltiplas entradas de ar.</p>
            <p><strong>Preço:</strong> R$ 320 - R$ 450 | <strong>Peso:</strong> 1.050g | <strong>Certificação:</strong> ECE 22.06</p>
            <p><a href="https://amzn.to/ls2of562" class="btn-buy" target="_blank" rel="noopener noreferrer">Ver na Amazon</a></p>
            
            <div class="pros-cons-grid">
              <div class="pc-col">
                <h4 class="pros">PRÓS</h4>
                <ul class="pc-list pros">
                  <li>Excelente custo-benefício</li>
                  <li>Acabamento superior</li>
                  <li>Leveza excepcional</li>
                  <li>Visibilidade periférica ampla</li>
                </ul>
              </div>
              <div class="pc-col">
                <h4 class="cons">CONTRAS</h4>
                <ul class="pc-list cons">
                  <li>Proteção limitada em quedas</li>
                  <li>Não indicado para altas velocidades</li>
                  <li>Viseira sem sistema de troca rápida</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- ARAI SZ-R -->
          <div class="product-section" id="arai-szr">
            <h3>3. Capacete Arai SZ-R Vas</h3>
            <div class="h2-image-card product-image">
              <img src="/images/arai-szr.jpg" alt="Capacete Arai SZ-R" />
            </div>
            <p>O Arai SZ-R Vas é o capacete aberto premium da marca japonesa, oferecendo segurança e qualidade excepcionais. Casco em composite resistente com sistema de ventilação difusa.</p>
            <p><strong>Preço:</strong> R$ 2.800 - R$ 3.500 | <strong>Peso:</strong> 1.200g | <strong>Certificação:</strong> ECE 22.06 / Snell</p>
            <p><a href="https://amzn.to/araiszr" class="btn-buy" target="_blank" rel="noopener noreferrer">Ver na Amazon</a></p>
            
            <div class="pros-cons-grid">
              <div class="pc-col">
                <h4 class="pros">PRÓS</h4>
                <ul class="pc-list pros">
                  <li>Segurança premium</li>
                  <li>Qualidade de construção impecável</li>
                  <li>Conforto prolongado</li>
                  <li>Proteção facial superior na categoria</li>
                </ul>
              </div>
              <div class="pc-col">
                <h4 class="cons">CONTRAS</h4>
                <ul class="pc-list cons">
                  <li>Preço elevado</li>
                  <li>Design conservador</li>
                  <li>Peças de reposição caras</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- AGV ORBYT -->
          <div class="product-section" id="agv-orbyt">
            <h3>4. Capacete AGV Orbyt Block</h3>
            <div class="h2-image-card product-image">
              <img src="/images/agv-orbyt.jpg" alt="Capacete AGV Orbyt" />
            </div>
            <p>O AGV Orbyt Block é o capacete aberto da marca italiana, com herança de competição e design esportivo. Casco em HIR-TH (termoplástico) com viseira GT2 anti-risco.</p>
            <p><strong>Preço:</strong> R$ 550 - R$ 750 | <strong>Preparado para intercom</strong> | <strong>Certificação:</strong> ECE 22.06</p>
            <p><a href="https://amzn.to/agvorbyt" class="btn-buy" target="_blank" rel="noopener noreferrer">Ver na Amazon</a></p>
            
            <div class="pros-cons-grid">
              <div class="pc-col">
                <h4 class="pros">PRÓS</h4>
                <ul class="pc-list pros">
                  <li>Design esportivo</li>
                  <li>Tecnologia da marca premium</li>
                  <li>Preparado para comunicação</li>
                  <li>Boa relação custo-benefício para marca premium</li>
                </ul>
              </div>
              <div class="pc-col">
                <h4 class="cons">CONTRAS</h4>
                <ul class="pc-list cons">
                  <li>Acabamento inferior ao Arai</li>
                  <li>Ventilação limitada em baixa velocidade</li>
                  <li>Isolamento acústico básico</li>
                </ul>
              </div>
            </div>
          </div>

          <h2 id="comparativo">Capacete Aberto vs Fechado</h2>
          <p>Capacetes abertos oferecem maior visibilidade e ventilação, mas protegem menos o rosto em caso de acidente. Ideais para uso urbano em baixas velocidades. Capacetes fechados (integrais) oferecem máxima proteção para todos os tipos de uso.</p>

          <div class="info-card-grid">
            <div class="info-card-content">
              <h4><a href="/melhor-capacete/">Capacetes Integrais</a></h4>
              <p>Máxima proteção para todos os tipos de uso</p>
            </div>
            <div class="info-card-content">
              <h4><a href="/custo-beneficio/">Capacetes Articulados</a></h4>
              <p>Versatilidade entre aberto e fechado</p>
            </div>
          </div>

          <h2 id="seguranca">⚠️ Importante: Segurança do Capacete Aberto</h2>
          <p>Capacetes abertos (3/4) oferecem <strong>menor proteção que os capacetes integrais</strong>. Eles não protegem o queixo e parte do rosto em caso de impacto.</p>
          <ul>
            <li>Indicado para uso urbano em velocidades até 60km/h</li>
            <li>Não recomendado para estradas ou velocidades elevadas</li>
            <li>Considere usar óculos de proteção ou viseira adicional</li>
            <li>Em caso de acidentes graves, a lesão facial pode ser severa</li>
          </ul>
          <p>Para maior segurança, considere um <a href="/melhor-capacete/">capacete integral</a> ou um <a href="/custo-beneficio/">capacete articulado</a>.</p>

          <h2 id="conclusao">Conclusão</h2>
          <p>Os capacetes abertos são uma excelente opção para quem busca conforto e praticidade no trânsito urbano. Modelos como o <strong>Norisk Darth</strong> e <strong>LS2 OF562</strong> oferecem ótimo custo-benefício, enquanto o <strong>Arai SZ-R</strong> representa o topo em segurança e qualidade.</p>
          <p>Lembre-se: a escolha do capacete ideal depende do seu tipo de uso. Para estradas e velocidades elevadas, prefira sempre um capacete integral.</p>

          <!-- TAGS E COMPARTILHAMENTO -->
          <div class="post-footer-meta">
            <div class="post-tags-container">
              <strong>TAGS:</strong>
              <div class="post-tags">
                <a href="/melhor-capacete/" class="post-tag">Capacetes</a>
                <a href="#" class="post-tag">Capacete Aberto</a>
                <a href="#" class="post-tag">3/4</a>
                <a href="#" class="post-tag">Urbando</a>
                <a href="#" class="post-tag">2026</a>
              </div>
            </div>
          </div>

          <div class="post-share-container">
            <strong>COMPARTILHE:</strong>
            <div class="post-share">
              <a href="https://www.facebook.com/profile.php?id=100088166945491" target="_blank" rel="noopener noreferrer" class="share-btn facebook" aria-label="Facebook">f</a>
              <a href="https://br.pinterest.com/jovemapan/" target="_blank" rel="noopener noreferrer" class="share-btn pinterest" aria-label="Pinterest">P</a>
              <a href="https://www.youtube.com/channel/UCChj9-uIY5ERfidZ6K-zt_w" target="_blank" rel="noopener noreferrer" class="share-btn youtube" aria-label="YouTube">▶</a>
              <a href="https://www.instagram.com/jovem_apan/" target="_blank" rel="noopener noreferrer" class="share-btn instagram" aria-label="Instagram">📷</a>
            </div>
          </div>

          <!-- BIO DO AUTOR -->
          <div class="author-bio-box" id="author">
            <div class="bio-avatar">
              <img src="/images/marcelo-ferreira.png" alt="Marcelo Ferreira" onerror="this.src='https://ui-avatars.com/api/?name=Marcelo+Ferreira&background=random'" />
            </div>
            <div class="bio-content">
              <h4 class="bio-name">Marcelo Ferreira</h4>
              <p class="bio-desc">
                Especialista em equipamentos de motociclismo com mais de 15 anos de experiência. 
                Já testou centenas de capacetes e acessórios, ajudando milhares de motociclistas 
                a fazerem a melhor escolha para sua segurança.
              </p>
              <a href="/sobre/" class="bio-link">SOBRE O AUTOR →</a>
            </div>
          </div>

          <!-- SEÇÃO DE COMENTÁRIOS -->
          <div class="post-comments-section" id="comments">
            <h3 class="comments-title">COMENTÁRIOS</h3>
            <p class="comments-note">Seu endereço de email não será publicado.</p>
            
            <form class="comments-form" onsubmit="event.preventDefault(); alert('Comentário enviado para moderação!');">
              <div class="form-group full-width">
                <textarea rows="5" placeholder="Deixe seu comentário..." required></textarea>
              </div>
              <div class="form-row">
                <input type="text" placeholder="Nome" required />
                <input type="email" placeholder="Email" required />
              </div>
              <button type="submit" class="btn-submit-comment">Publicar Comentário</button>
            </form>
          </div>

        </article>

        <!-- [DIREITA] Sidebar -->
        <aside class="post-sidebar-col">
          
          <!-- Widget 1: PRODUTO EM DESTAQUE -->
