---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Intercomunicador Ejeas Review: Vale a Pena em 2026?';
const description = 'Review completo dos intercomunicadores Ejeas. Modelos, qualidade de áudio, autonomia, alcance e se é uma alternativa viável aos gigantes do mercado.';
const canonical = 'https://jovemapan.com.br/intercomunicador-ejeas-review/';
const author = 'Marcelo Ferreira';
const authorImage = '/images/marcelo-ferreira.png';
const publishDate = '2026-04-23';
const category = 'Reviews';
const categoryHref = '/category/reviews/';
const coverImage = '/images/moto-shop-cover.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. Modelos da Ejeas', href: '#modelos' },
  { label: '3. Qualidade e autonomia', href: '#qualidade' },
  { label: '4. Vale a pena comprar?', href: '#vale-a-pena' },
  { label: '5. Conclusão', href: '#conclusao' },
];

const tags = [
  { label: 'REVIEW', href: '#' },
  { label: 'EJEAS', href: '#' },
  { label: 'INTERCOMUNICADOR', href: '/melhor-capacete/intercomunicadores/' },
  { label: '2026', href: '#' },
];

const featuredProduct = {
  preTitle: 'APROVEITE FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete Shoei Premium Edition',
  name: 'Capacete Shoei<br/>Premium Edition',
  mercadoLivreHref: '#',
  amazonHref: '#',
};

const authorBio = {
  name: author,
  description: 'Redator & Editor especializado em transformar especificações técnicas complexas em conteúdo claro, envolvente e acessível.',
  image: authorImage,
  profileHref: '/author-marcelo-ferreira/',
  profileLabel: 'Ver perfil completo ›',
};
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  authorImage={authorImage}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  featuredProduct={featuredProduct}
>
  <p class="post-lead" id="introducao">
    Conteúdo do post em breve.
  </p>

  <h2 id="modelos">Modelos da Ejeas</h2>
  <p>Em breve.</p>

  <h2 id="qualidade">Qualidade e autonomia</h2>
  <p>Em breve.</p>

  <h2 id="vale-a-pena">Vale a pena comprar?</h2>
  <p>Em breve.</p>

  <h2 id="conclusao">Conclusão</h2>
  <p>Em breve.</p>
</PostLayout>
