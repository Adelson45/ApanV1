---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Axxis Draken Review 2026 | Análise Completa do Capacete';
const description = 'Review completo do capacete Axxis Draken. Análise do modelo sport com design agressivo, preço, qualidade e vale a pena comprar?';
const canonical   = 'https://jovemapan.com.br/axxis-draken-review/';
const author      = 'Arthur Gomes';
const publishDate = '24 ABR, 2026';
const category    = 'REVIEWS';
const categoryHref = '/category/reviews/';
const coverImage  = '/images/capacete-axxis-draker-1.png';
const views       = '14K VIEWS';
const comments    = '10 COMMENTS';

const indice = [
  {
    "label": "Introdução",
    "href": "#introducao"
  },
  {
    "label": "Resumo da Análise",
    "href": "#resumo"
  },
  {
    "label": "Especificações Técnicas",
    "href": "#especificacoes"
  },
  {
    "label": "Prós e Contras",
    "href": "#pros-contras"
  },
  {
    "label": "Vale a Pena Comprar?",
    "href": "#veredicto"
  }
];
const tags = [
  {
    "label": "REVIEWS",
    "href": "/category/reviews/"
  },
  {
    "label": "AXXIS",
    "href": "#"
  },
  {
    "label": "SPORT",
    "href": "#"
  }
];

const authorBio = {
  name: 'Arthur Gomes',
  description: 'Especialista em reviews de motos e equipamentos.',
  image: '/images/arthur-gomes.png',
  profileHref: '/author-arthur-gomes/',
  profileLabel: 'Ver perfil completo ›'
};

const featuredProduct = {
  preTitle: 'DESTAQUE',
  image: '/images/capacete-axxis-draker-1.png',
  imageAlt: 'Axxis Draken Review 2026 | Análise Completa do Capacete',
  name: 'Axxis Draken Review 2026',
  amazonHref: 'https://amzn.to/axxiseagle',
  mercadoLivreHref: 'javascript:void(0)'
};

const specs = [
  { label: 'Material', value: 'Policarbonato de alto impacto' },
  { label: 'Peso', value: '1.350g (±50g)' },
  { label: 'Certificações', value: 'ECE 22.05, DOT, INMETRO' },
  { label: 'Viseira', value: 'Policarbonato 2D anti-risco' },
  { label: 'Viseira Solar', value: 'Não incluso' },
  { label: 'Ventilação', value: '4 entradas + 2 exaustores' },
  { label: 'Forro', value: 'Removível e lavável' },
  { label: 'Fechamento', value: 'Micrométrico' },
  { label: 'Preço', value: 'R$ 420 - R$ 600' }
];

const pros = [
  'Design esportivo agressivo e moderno',
  'Excelente relação custo-benefício',
  'Peso leve para categoria sport',
  'Boa ventilação',
  'Certificações múltiplas',
  'Preço competitivo',
  'Ótimo para iniciantes no estilo sport',
  'Disponível em várias cores vibrantes'
];

const cons = [
  'Sem viseira solar integrada',
  'Acabamento inferior a marcas premium',
  'Isolamento acústico básico',
  'Forro menos macio que concorrentes',
  'Mecanismo de viseira simples',
  'Resistência a arranhões limitada'
];

const verdict = {
  recommend: [
    'Jovens e pilotos que valorizam estética',
    'Quem busca capacete esportivo acessível',
    'Uso urbano e estradista ocasional',
    'Orçamento até R$ 600',
    'Pilotos de motos naked/sport'
  ],
  notRecommend: [
    'Quem precisa de viseira solar',
    'Pilotos de longas viagens',
    'Quem busca máximo conforto',
    'Velocidades muito elevadas'
  ]
};
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  views={views}
  comments={comments}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  featuredProduct={featuredProduct}
>
\n
<p class="post-lead" id="introducao">
  Review completo do capacete sport da Axxis. Design agressivo 
          com preço competitivo para pilotos que buscam estilo.
</p>
<div style="background: var(--gray-light); padding: 20px; border-radius: 8px; border-left: 4px solid var(--red); margin-bottom: 30px;">
  <span style="font-size: 1.2rem; font-weight: bold; color: var(--red); display: block; margin-bottom: 5px;">Veredito: Bom</span>
  <p style="margin: 0;">Estilo esportivo com preço justo</p>
</div>


    <section class="summary-section" id="resumo">
      <div class="container">
        <div class="summary-box">
          <h2>Resumo da Análise</h2>
          <p>
            O <strong>Axxis Draken</strong> é um capacete voltado para o público jovem e 
            esportivo que busca <strong>estética agressiva</strong> sem pagar o preço de 
            marcas premium. Seu design é o grande destaque, com linhas angulares e cores vibrantes.
          </p>
          <p>
            Apesar do visual racing, é mais indicado para <strong>uso urbano</strong> e 
            estradas ocasionais. Não possui viseira solar integrada, o que pode ser um 
            ponto negativo para alguns usuários.
          </p>
          <div class="rating-summary">
            <div class="rating-item"><span class="rating-number">4.5</span><span class="rating-label">Nota Geral</span></div>
            <div class="rating-item"><span class="rating-stars">★★★★☆</span><span class="rating-label">Design</span></div>
            <div class="rating-item"><span class="rating-recommend">78%</span><span class="rating-label">Recomendam</span></div>
          </div>
        </div>
      </div>
    </section>

    <section class="specs-section" id="especificacoes">
      <div class="container">
        <h2>Especificações</h2>
        <div class="specs-grid">
          <div class="specs-image">
            <img src="/images/capacete-axxis-draker-1.png" alt="Axxis Draken" loading="lazy" />
          </div>
          <div class="specs-table">
            {specs.map(spec => (
              <div class="spec-row">
                <span class="spec-label">{spec.label}</span>
                <span class="spec-value">{spec.value}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="pros-cons-section" id="pros-contras">
      <div class="container">
        <div class="pros-cons-grid">
          <div class="pros-box">
            <h3>✓ Pontos Positivos</h3>
            <ul>{pros.map(pro => <li>{pro}</li>)}</ul>
          </div>
          <div class="cons-box">
            <h3>✗ Pontos Negativos</h3>
            <ul>{cons.map(con => <li>{con}</li>)}</ul>
          </div>
        </div>
      </div>
    </section>

    <section class="final-verdict-section" id="veredicto">
      <div class="container">
        <div class="verdict-box">
          <h2>Vale a Pena?</h2>
          <div class="verdict-content">
            <div class="verdict-recommend">
              <span class="recommend-badge">👍 Sim</span>
              <ul>{verdict.recommend.map(item => <li>{item}</li>)}</ul>
            </div>
            <div class="verdict-not-recommend">
              <span class="not-recommend-badge">👎 Não</span>
              <ul>{verdict.notRecommend.map(item => <li>{item}</li>)}</ul>
            </div>
          </div>
          <div class="final-cta">
            <p class="final-opinion">
              <strong>Opinião:</strong> O Draken é uma escolha acertada para quem busca 
              estilo esportivo pagando pouco. Não espere conforto premium, mas o visual 
              compensa para uso urbano.
            </p>
            <a href="https://amzn.to/axxiseagle" target="_blank" rel="nofollow noopener" class="btn btn-primary">Ver Preço</a>
          </div>
        </div>
      </div>
    </section>

    \n\n\n</PostLayout>\n