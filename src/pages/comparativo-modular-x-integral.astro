---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Comparativo: Capacete Modular x Integral — Qual o Melhor?';
const description = 'Comparativo completo entre capacete modular e integral. Vantagens, desvantagens, segurança, conforto e qual escolher para o seu estilo de pilotagem.';
const canonical = 'https://jovemapan.com.br/comparativo-modular-x-integral/';
const author = 'Marcelo Ferreira';
const authorImage = '/images/marcelo-ferreira.png';
const publishDate = '2026-04-23';
const category = 'Comparativos';
const categoryHref = '/melhor-capacete/';
const coverImage = '/images/moto-shop-cover.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. O que é um capacete modular', href: '#modular' },
  { label: '3. O que é um capacete integral', href: '#integral' },
  { label: '4. Comparativo direto', href: '#comparativo' },
  { label: '5. Conclusão', href: '#conclusao' },
];

const tags = [
  { label: 'COMPARATIVO', href: '#' },
  { label: 'MODULAR', href: '#' },
  { label: 'INTEGRAL', href: '#' },
  { label: '2026', href: '#' },
];

const featuredProduct = {
  preTitle: 'APROVEITE FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete Shoei Premium Edition',
  name: 'Capacete Shoei<br/>Premium Edition',
  mercadoLivreHref: '#',
  amazonHref: '#',
};

const authorBio = {
  name: author,
  description: 'Redator & Editor especializado em transformar especificações técnicas complexas em conteúdo claro, envolvente e acessível.',
  image: authorImage,
  profileHref: '/author-marcelo-ferreira/',
  profileLabel: 'Ver perfil completo ›',
};
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  authorImage={authorImage}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  featuredProduct={featuredProduct}
>
  <p class="post-lead" id="introducao">
    Conteúdo do post em breve.
  </p>

  <h2 id="modular">O que é um capacete modular</h2>
  <p>Em breve.</p>

  <h2 id="integral">O que é um capacete integral</h2>
  <p>Em breve.</p>

  <h2 id="comparativo">Comparativo direto</h2>
  <p>Em breve.</p>

  <h2 id="conclusao">Conclusão</h2>
  <p>Em breve.</p>
</PostLayout>
