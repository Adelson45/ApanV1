---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Melhores Capacetes Para Moto de Alta Cilindrada | Top 10';
const description = 'Guia completo dos melhores capacetes para motos de alta cilindrada (acima de 600cc): Arai, Shoei, Shark, AGV, MT, HJC, LS2, Bell, Axxis e Norisk.';
const canonical = 'https://jovemapan.com.br/capacete-alta-cilindrada/';
const author = 'Pamela Pan';
const authorImage = '/images/Pamela%20pan%20coufundadora%20e%20editoara%20chefe%20do%20blog%20apan%20.png';
const publishDate = '2026-01-12';
const category = 'Capacetes';
const categoryHref = '/melhor-capacete/';
const coverImage = '/images/melhores capacete de moto para alto cilindrada.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. Por que capacetes para alta cilindrada são diferentes', href: '#diferenca' },
  { label: '3. Critérios de escolha', href: '#criterios' },
  { label: '4. Viseira e durabilidade', href: '#viseira' },
  { label: '5. Top 10 Marcas', href: '#top10' },
  { label: '6. Como escolher o melhor capacete', href: '#como-escolher' },
  { label: '7. Limpeza e manutenção', href: '#limpeza' },
  { label: '8. Perguntas Frequentes', href: '#faq' },
  { label: '9. Conclusão', href: '#conclusao' },
];

const tags = [
  { label: 'CAPACETES', href: '/melhor-capacete/' },
  { label: 'ALTA CILINDRADA', href: '#' },
  { label: 'SEGURANÇA', href: '/capacetes-mais-seguros/' },
  { label: 'PREMIUM', href: '#' },
  { label: '2026', href: '#' },
];

const featuredProduct = {
  preTitle: 'TOP DE LINHA',
  image: '/images/Capacete Shoei X-Spirit3 Norick 04 Tc-2 60.png',
  imageAlt: 'Capacete Shoei X-Spirit3',
  name: 'Shoei<br/>X-Spirit3',
  mercadoLivreHref: 'https://mercadolivre.com/sec/12PXYG7',
  amazonHref: 'https://amzn.to/3IuPxvm',
