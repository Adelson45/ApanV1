---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Comparativo Jaqueta Texx vs X11: Qual a Melhor para o Motociclista?';
const description = 'Texx ou X11? Comparativo completo entre as duas marcas líderes em jaquetas de moto. Proteção, conforto, preço e qual escolher em 2026.';
const canonical = 'https://jovemapan.com.br/comparativo-jaqueta-texx-vs-x11/';
const author = 'Marcelo Ferreira';
const authorImage = '/images/marcelo-ferreira.png';
const publishDate = '2026-04-23';
const category = 'Comparativos';
const categoryHref = '/dica-melhor-jaqueta-motociclistas/';
const coverImage = '/images/moto-shop-cover.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. Jaqueta Texx: características', href: '#texx' },
  { label: '3. Jaqueta X11: características', href: '#x11' },
  { label: '4. Comparativo direto', href: '#comparativo' },
  { label: '5. Conclusão', href: '#conclusao' },
];

const tags = [
  { label: 'COMPARATIVO', href: '#' },
  { label: 'TEXX', href: '#' },
  { label: 'X11', href: '#' },
  { label: 'JAQUETAS', href: '/dica-melhor-jaqueta-motociclistas/' },
];

const featuredProduct = {
  preTitle: 'APROVEITE FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete Shoei Premium Edition',
  name: 'Capacete Shoei<br/>Premium Edition',
  mercadoLivreHref: '#',
  amazonHref: '#',
};

const authorBio = {
  name: author,
  description: 'Redator & Editor especializado em transformar especificações técnicas complexas em conteúdo claro, envolvente e acessível.',
  image: authorImage,
  profileHref: '/author-marcelo-ferreira/',
  profileLabel: 'Ver perfil completo ›',
};
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  authorImage={authorImage}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  featuredProduct={featuredProduct}
>
  <p class="post-lead" id="introducao">
    Conteúdo do post em breve.
  </p>

  <h2 id="texx">Jaqueta Texx: características</h2>
  <p>Em breve.</p>

  <h2 id="x11">Jaqueta X11: características</h2>
  <p>Em breve.</p>

  <h2 id="comparativo">Comparativo direto</h2>
  <p>Em breve.</p>

  <h2 id="conclusao">Conclusão</h2>
  <p>Em breve.</p>
</PostLayout>
