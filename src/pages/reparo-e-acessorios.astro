---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Reparo e Acessórios para Capacete de Moto';
const description = 'Guia completo sobre reparo e acessórios para capacete de moto: viseiras, forros, pinos, antiembaçantes, ganchos e mais. Mantenha seu equipamento como novo.';
const canonical = 'https://jovemapan.com.br/reparo-e-acessorios/';
const author = 'Marcelo Ferreira';
const authorImage = '/images/marcelo-ferreira.png';
const publishDate = '2026-04-23';
const category = 'Acessórios';
const categoryHref = '/melhor-capacete/';
const coverImage = '/images/moto-shop-cover.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. Peças que podem ser trocadas', href: '#pecas' },
  { label: '3. Acessórios que fazem diferença', href: '#acessorios' },
  { label: '4. Quando vale reparar e quando vale trocar', href: '#reparar-trocar' },
  { label: '5. Conclusão', href: '#conclusao' },
];

const tags = [
  { label: 'ACESSÓRIOS', href: '#' },
  { label: 'REPARO', href: '#' },
  { label: 'MANUTENÇÃO', href: '#' },
  { label: '2026', href: '#' },
];

const featuredProduct = {
  preTitle: 'APROVEITE FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete Shoei Premium Edition',
  name: 'Capacete Shoei<br/>Premium Edition',
  mercadoLivreHref: '#',
  amazonHref: '#',
};

const authorBio = {
  name: author,
  description: 'Redator & Editor especializado em transformar especificações técnicas complexas em conteúdo claro, envolvente e acessível.',
  image: authorImage,
  profileHref: '/author-marcelo-ferreira/',
  profileLabel: 'Ver perfil completo ›',
};
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  authorImage={authorImage}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  featuredProduct={featuredProduct}
>
  <p class="post-lead" id="introducao">
    Conteúdo do post em breve.
  </p>

  <h2 id="pecas">Peças que podem ser trocadas</h2>
  <p>Em breve.</p>

  <h2 id="acessorios">Acessórios que fazem diferença</h2>
  <p>Em breve.</p>

  <h2 id="reparar-trocar">Quando vale reparar e quando vale trocar</h2>
  <p>Em breve.</p>

  <h2 id="conclusao">Conclusão</h2>
  <p>Em breve.</p>
</PostLayout>
