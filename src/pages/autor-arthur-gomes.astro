---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Arthur Gomes | Estradeiro e Redator Jovem Apan';
const description = 'Arthur Gomes é a energia aventureira e a voz clara do Jovem Apan. Estradeiro nato e apaixonado por longas viagens.';

const authorBio = {
  name: 'Arthur Gomes',
  description: 'Redator Principal focado em transformar quilômetros em conhecimento prático.',
  image: '/images/Arthur .png',
  profileHref: '/autor-arthur-gomes/',
  profileLabel: 'Ver perfil completo ›'
};

const indice = [
  { label: 'Bio', href: '#introducao' },
  { label: 'Destaques', href: '#destaques' },
  { label: 'Experiência', href: '#experiencia' },
  { label: 'Educação', href: '#educacao' },
];
---

<PostLayout
  title={title}
  description={description}
  category="EQUIPE"
  author="Arthur Gomes"
  authorBio={authorBio}
  coverImage="/images/Arthur .png"
  indice={indice}
  hideShare={true}
  hideAuthor={true}
  hideComments={true}
>
  <div class="author-profile-header" id="introducao">
    <div class="author-photo">
      <img src="/images/Arthur .png" alt="Arthur Gomes" />
    </div>
    <span class="author-role">Redator Principal</span>
    <h1 class="author-name">Arthur Gomes</h1>
    <div class="author-title">
      <span class="icon">🛣️</span> Especialista em Viagens e Rotas
    </div>
    <p class="author-intro-text">
      Arthur Gomes é a energia aventureira e a voz clara do Jovem Apan. Estradeiro nato e apaixonado por longas viagens, ele transforma cada quilômetro percorrido em conhecimento prático. Com uma escrita objetiva e acessível, Arthur tem o talento único de traduzir assuntos complexos como mecânica, segurança e performance em conteúdos que qualquer motociclista consegue entender.
    </p>
  </div>

  <h2 id="destaques">Destaques</h2>
  <div class="highlights-grid">
    <div class="highlight-card">
      <div class="highlight-icon">🗺️</div>
      <h3>Especialista em Viagens e Rotas</h3>
      <p>Especialista em viagens, rotas e experiência real na estrada, com habilidade em simplificar conteúdos técnicos sem perder precisão.</p>
    </div>
    <div class="highlight-card">
      <div class="highlight-icon">🛡️</div>
      <h3>Segurança e Manutenção</h3>
      <p>Referência interna em temas de pilotagem, segurança e manutenção, com estilo de escrita leve, direto e envolvente.</p>
    </div>
    <div class="highlight-card">
      <div class="highlight-icon">✍️</div>
      <h3>Comunicação Clara</h3>
      <p>Combinação rara de vivência prática com comunicação clara. Se um artigo nosso parece fácil e gostoso de ler, agradeça ao Arthur.</p>
    </div>
    <div class="highlight-card">
      <div class="highlight-icon">🏍️</div>
      <h3>Vivência Real</h3>
      <p>Anos rodando pelas estradas brasileiras, vivenciando desafios, testando equipamentos e conhecendo diferentes estilos de pilotagem.</p>
    </div>
  </div>

  <h2 id="experiencia">Experiência</h2>
  <div class="timeline">
    <div class="timeline-item">
      <h3>Redator Principal</h3>
      <p><strong>Jovem Apan</strong></p>
      <p>Responsável por transformar informações densas — como análises técnicas, comparativos e guias de pilotagem — em conteúdos fáceis, agradáveis e confiáveis. Dá vida às pautas relacionadas a estrada, experiência real, viagens e usabilidade de equipamentos.</p>
    </div>
    <div class="timeline-item">
      <h3>Produtor de Conteúdo Independente</h3>
      <p><strong>Projetos de Turismo sobre Duas Rodas</strong></p>
      <p>Colaborou com projetos de turismo sobre duas rodas e produziu conteúdos independentes sobre viagens, equipamentos e experiências de estrada.</p>
    </div>
  </div>

  <h2 id="educacao">Educação</h2>
  <ul class="education-list">
    <li><strong>Formação em Letras:</strong> Foco em escrita e clareza comunicativa.</li>
    <li><strong>Cursos complementares:</strong> Técnicas de pilotagem, segurança no trânsito e mecânica básica.</li>
    <li><strong>Certificações:</strong> Produção de conteúdo, storytelling e revisão técnica.</li>
  </ul>

  <blockquote class="author-quote">
    <p>"Minha missão é clara: mostrar que qualquer motociclista pode aprender, evoluir e aproveitar mais cada trajeto, independentemente do nível de experiência."</p>
    <cite>— Arthur Gomes</cite>
  </blockquote>
</PostLayout>

<style>
  .author-profile-header {
    text-align: center;
    background: #fff;
    border: 1px solid #eee;
    border-radius: 24px;
    padding: 60px 40px;
    margin-bottom: 40px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .author-photo {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    border: 4px solid #e31b1b;
    padding: 10px;
    margin-bottom: 25px;
    background: #fff;
    box-shadow: 0 10px 40px rgba(227, 27, 27, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .author-photo:hover {
    transform: scale(1.02);
  }

  .author-photo img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
  }

  .author-role {
    font-size: 1rem;
    color: #666;
    font-weight: 400;
    margin-bottom: 12px;
    display: block;
  }

  .author-name {
    font-size: 2.5rem;
    font-weight: 800;
    color: #e31b1b;
    margin-bottom: 10px;
  }

  .author-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #333;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
  }

  .author-intro-text {
    font-size: 1.05rem;
    color: #555;
    line-height: 1.8;
    max-width: 700px;
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin: 30px 0;
  }
  .highlight-card {
    background: #fdfdfd;
    border: 1px solid #eee;
    border-radius: 16px;
    padding: 24px;
  }
  .highlight-icon { font-size: 2rem; margin-bottom: 10px; }
  .highlight-card h3 { font-size: 1.1rem; margin-bottom: 8px; }
  
  .timeline-item {
    margin-bottom: 24px;
    padding-left: 20px;
    border-left: 3px solid #e31b1b;
  }
  
  .author-quote {
    background: #fafafa;
    border-left: 4px solid #e31b1b;
    padding: 20px 30px;
    margin: 40px 0;
    font-style: italic;
  }
  
  @media (max-width: 768px) {
    .highlights-grid { grid-template-columns: 1fr; }
    .author-name { font-size: 2rem; }
  }
</style>


