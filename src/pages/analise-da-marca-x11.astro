---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Análise da Marca X11: Vale a Pena Comprar?';
const description = 'Análise completa da marca X11. História, qualidade, certificações, principais produtos e se vale a pena investir em capacetes e jaquetas X11 em 2026.';
const canonical = 'https://jovemapan.com.br/analise-da-marca-x11/';
const author = 'Marcelo Ferreira';
const authorImage = '/images/marcelo-ferreira.png';
const publishDate = '2026-04-23';
const category = 'Marcas';
const categoryHref = '/category/reviews/';
const coverImage = '/images/moto-shop-cover.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. História da X11', href: '#historia' },
  { label: '3. Linha de produtos', href: '#produtos' },
  { label: '4. Vale a pena?', href: '#vale-a-pena' },
  { label: '5. Conclusão', href: '#conclusao' },
];

const tags = [
  { label: 'MARCA', href: '#' },
  { label: 'X11', href: '#' },
  { label: 'ANÁLISE', href: '#' },
  { label: '2026', href: '#' },
];

const featuredProduct = {
  preTitle: 'APROVEITE FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete Shoei Premium Edition',
  name: 'Capacete Shoei<br/>Premium Edition',
  mercadoLivreHref: '#',
  amazonHref: '#',
};

const authorBio = {
  name: author,
  description: 'Redator & Editor especializado em transformar especificações técnicas complexas em conteúdo claro, envolvente e acessível.',
  image: authorImage,
  profileHref: '/author-marcelo-ferreira/',
  profileLabel: 'Ver perfil completo ›',
};
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  authorImage={authorImage}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  featuredProduct={featuredProduct}
>
  <p class="post-lead" id="introducao">Conteúdo do post em breve.</p>
  <h2 id="historia">História da X11</h2>
  <p>Em breve.</p>
  <h2 id="produtos">Linha de produtos</h2>
  <p>Em breve.</p>
  <h2 id="vale-a-pena">Vale a pena?</h2>
  <p>Em breve.</p>
  <h2 id="conclusao">Conclusão</h2>
  <p>Em breve.</p>
</PostLayout>
