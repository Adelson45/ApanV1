  { label: '4. Qual escolher?', href: '#comparativo' },
  { label: '5. Perguntas Frequentes', href: '#faq' },
  { label: '6. Conclusão', href: '#conclusao' },
];

const tags = [
  { label: 'REVIEWS', href: '/category/reviews/' },
  { label: 'AXXIS', href: '#' },
