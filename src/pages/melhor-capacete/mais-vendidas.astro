---
import PostLayout from '../../layouts/PostLayout.astro';

const title = 'Marcas de Capacetes Mais Vendidos em 2026';
const description = 'As 10 marcas de capacete mais vendidas do mundo em 2026. Shoei, Arai, HJC, Bell, Shark, LS2, Norisk, Scorpion EXO, Nolan e MT — análise completa.';
const canonical = 'https://jovemapan.com.br/melhor-capacete/mais-vendidas/';
const author = 'Pamela Pan';
const authorImage = '/images/Pamela%20pan%20coufundadora%20e%20editoara%20chefe%20do%20blog%20apan%20.png';
const publishDate = '2025-09-25';
const category = 'Capacetes';
const categoryHref = '/melhor-capacete/';
const coverImage = '/images/Melhores-marcas-de-Capacetes-motos-no-brasil.png';

const indice = [
  { label: 'Top 10 marcas mais vendidas', href: '#top10', children: [
    { label: '1. Shoei GT-Air 3', href: '#shoei-gtair3' },
    { label: '2. Arai Corsair-X', href: '#arai-corsair' },
    { label: '3. HJC RPHA 11', href: '#hjc-rpha11' },
    { label: '4. Bell Bullitt', href: '#bell-bullitt' },
    { label: '5. Shark Spartan', href: '#shark-spartan' },
    { label: '6. LS2 Vector II', href: '#ls2-vector' },
    { label: '7. Norisk Razor', href: '#norisk-razor' },
    { label: '8. Scorpion EXO R1 Air', href: '#scorpion-r1' },
    { label: '9. Nolan N100-5', href: '#nolan-n100' },
    { label: '10. MT Helmets Revenge 2', href: '#mt-revenge' }
  ]},
  { label: 'Mais vendidos na Amazon', href: '#amazon' },
  { label: 'Como escolher a melhor marca', href: '#como-escolher' },
  { label: 'Perguntas Frequentes', href: '#faq' },
  { label: 'Conclusão', href: '#conclusao' }
];

const tags = [
  { label: 'CAPACETES', href: '#' },
  { label: 'MAIS VENDIDOS', href: '#' },
  { label: '2026', href: '#' }
];

const authorBio = {
  name: 'Pamela Pan',
  description: 'Velocidade no DNA, segurança na cabeça. Eu sou Pamela Pan, piloto profissional de moto.',
  image: '/images/Pamela pan coufundadora e editoara chefe do blog apan .png',
  profileHref: '/author-pamela-pan/',
  profileLabel: 'Ver perfil completo ›'
};

const extraProducts = [
  {
    badge: 'Aproveite frete GRÁTIS',
    badgeStyle: 'frete' as const,
    image: '/images/Capacete Aberto Moto Peels Mirage Classic Branco.png',
    imageAlt: 'Peels Mirage Classic',
    name: 'Capacete Peels Mirage Classic',
    mercadoLivreHref: 'https://mercadolivre.com/sec/1qaAz5s',
    amazonHref: 'https://amzn.to/3MjKWy9'
  }
];
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  extraProducts={extraProducts}
>

<p class="post-lead">
  Quais são as <strong>marcas de capacete mais vendidas em 2026</strong>? Combinamos dados de mercado, popularidade global e modelos campeões de venda para apresentar este ranking.
</p>

