    { label: '5. Mixs MX Gladiator', href: '#mixs-gladiator' },
    { label: '6. Peels Freeway', href: '#peels-freeway' },
    { label: '7. JOY23 Street', href: '#joy23-street' },
    { label: '8. Taurus', href: '#taurus' },
    { label: '9. Pro Tork New Liberty', href: '#liberty' },
    { label: '10. Fly New Jet', href: '#fly-newjet' }
  ]},
  { label: 'Para longas viagens', href: '#viagens' },
  { label: 'Conclusão', href: '#conclusao' }
];

const tags = [
  { label: 'CAPACETES', href: '#' },
  { label: 'LEVES', href: '#' },
  { label: 'CONFORTO', href: '#' }
];

const authorBio = {
  name: 'Pamela Pan',
  description: 'Velocidade no DNA, segurança na cabeça. Eu sou Pamela Pan, piloto profissional de moto.',
  image: '/images/Pamela pan coufundadora e editoara chefe do blog apan .png',
  profileHref: '/author-pamela-pan/',
  profileLabel: 'Ver perfil completo ›'
