const category = 'Capacetes';
const categoryHref = '/melhor-capacete/';
const coverImage = '/images/Capacete LS2 Stream 2 FF808 Vintage Branco Azul e Vermelho Brilhante Masculino.png';

const indice = [
  { label: 'Como escolher um capacete leve', href: '#como-escolher' },
  { label: 'Materiais utilizados', href: '#materiais' },
  { label: 'Top 10 capacetes leves', href: '#top10', children: [
    { label: '1. Axxis Gecko Capital', href: '#axxis-gecko' },
    { label: '2. Bieffe B-Dynamic', href: '#bieffe-bdynamic' },
    { label: '3. Peels TR1', href: '#peels-tr1' },
