    <div class="item-capacete">
      <div class="info-capacete">
        <img src="https://jovemapan.com.br/wp-content/uploads/2025/06/Capacete-Norisk-verde-e-preto.png" alt="Senhill ATV Offroad" />
        <div class="modelo">5. Norisk Capacete Darth 2</div>
      </div>
