    </div>
    <div class="btn-buy-container">
      <a href="https://amzn.to/45Dxhtx" class="btn-buy" target="_blank" rel="nofollow noopener noreferrer">Ver na Amazon</a>
      <a href="https://mercadolivre.com/sec/2C8xGeq" class="btn-buy ml" target="_blank" rel="nofollow noopener noreferrer">Ver no Mercado Livre</a>
