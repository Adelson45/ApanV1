const title = 'Melhor Capacete para Quem Usa Óculos: Guia Completo';
const description = 'Descubra os melhores capacetes de moto para quem usa óculos: modulares, abertos, integrais e meio capacetes. Veja modelos, dicas e o que diz a lei.';
const canonical = 'https://jovemapan.com.br/capacete-para-quem-usa-oculos/';
const author = 'Pamela Pan';
const authorImage = '/images/Pamela pan coufundadora e editoara chefe do blog apan .png';
const publishDate = '2026-04-23';
const category = 'Guias';
const categoryHref = '/melhor-capacete/';
const coverImage = '/images/Homem-pilotando-sua-moto-usando-oculos-de-grau.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. Capacetes modulares', href: '#modulares' },
  { label: '3. Capacetes integrais', href: '#integrais' },
  { label: '4. Capacetes abertos', href: '#abertos' },
  { label: '5. Meio capacetes', href: '#meio' },
  { label: '6. O que diz a lei', href: '#lei' },
  { label: '7. Perguntas frequentes', href: '#faq' },
  { label: '8. Considerações finais', href: '#conclusao' },
