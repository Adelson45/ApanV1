---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Capacete para Quem Usa Óculos: Como Escolher o Modelo Ideal';
const description = 'Usa óculos de grau? Veja os melhores capacetes de moto com espaço para hastes, forros removíveis e ajuste confortável para quem depende das lentes.';
const canonical = 'https://jovemapan.com.br/capacete-para-quem-usa-oculos/';
const author = 'Marcelo Ferreira';
const authorImage = '/images/marcelo-ferreira.png';
const publishDate = '2026-04-23';
const category = 'Guias';
const categoryHref = '/melhor-capacete/';
const coverImage = '/images/moto-shop-cover.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. O que observar na compra', href: '#criterios' },
  { label: '3. Tipos recomendados', href: '#tipos' },
  { label: '4. Dicas de ajuste', href: '#ajuste' },
  { label: '5. Conclusão', href: '#conclusao' },
];

const tags = [
  { label: 'GUIA', href: '#' },
  { label: 'ÓCULOS', href: '#' },
  { label: 'CONFORTO', href: '#' },
  { label: '2026', href: '#' },
];

const featuredProduct = {
  preTitle: 'APROVEITE FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete Shoei Premium Edition',
  name: 'Capacete Shoei<br/>Premium Edition',
  mercadoLivreHref: '#',
  amazonHref: '#',
};

const authorBio = {
  name: author,
  description: 'Redator & Editor especializado em transformar especificações técnicas complexas em conteúdo claro, envolvente e acessível.',
  image: authorImage,
  profileHref: '/author-marcelo-ferreira/',
  profileLabel: 'Ver perfil completo ›',
};
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  authorImage={authorImage}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  featuredProduct={featuredProduct}
>
  <p class="post-lead" id="introducao">
    Conteúdo do post em breve.
  </p>

  <h2 id="criterios">O que observar na compra</h2>
  <p>Em breve.</p>

  <h2 id="tipos">Tipos recomendados</h2>
  <p>Em breve.</p>

  <h2 id="ajuste">Dicas de ajuste</h2>
  <p>Em breve.</p>

  <h2 id="conclusao">Conclusão</h2>
  <p>Em breve.</p>
</PostLayout>
