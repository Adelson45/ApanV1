        </article>

        <!-- [DIREITA] Sidebar -->
        <aside class="post-sidebar-col">
          
          <!-- Widget Produto em Destaque -->
          <div class="sidebar-widget produto-destaque">
            <p class="frete-gratis">Aproveite frete GRÁTIS</p>
            <img src="/images/capacete-shoei.png" alt="Capacete Shoei" class="produto-imagem" />
