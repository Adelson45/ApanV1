---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Multa por Dirigir Sem Capacete: Valor, Pontos e Consequências';
const description = 'Saiba o valor da multa por dirigir moto sem capacete, quantos pontos na CNH, riscos legais e por que o capacete é o item mais importante da pilotagem.';
const canonical = 'https://jovemapan.com.br/multa-dirigir-sem-capacete/';
const author = 'Marcelo Ferreira';
const authorImage = '/images/marcelo-ferreira.png';
const publishDate = '2026-04-23';
const category = 'Legislação';
const categoryHref = '/melhor-capacete/';
const coverImage = '/images/moto-shop-cover.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. Valor da multa e pontuação', href: '#valor-pontos' },
  { label: '3. O que diz o CTB', href: '#ctb' },
  { label: '4. Riscos além da multa', href: '#riscos' },
  { label: '5. Conclusão', href: '#conclusao' },
];

const tags = [
  { label: 'MULTA', href: '#' },
  { label: 'LEGISLAÇÃO', href: '#' },
  { label: 'CTB', href: '#' },
  { label: '2026', href: '#' },
];

const featuredProduct = {
  preTitle: 'APROVEITE FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete Shoei Premium Edition',
  name: 'Capacete Shoei<br/>Premium Edition',
  mercadoLivreHref: '#',
  amazonHref: '#',
};

const authorBio = {
  name: author,
  description: 'Redator & Editor especializado em transformar especificações técnicas complexas em conteúdo claro, envolvente e acessível.',
  image: authorImage,
  profileHref: '/author-marcelo-ferreira/',
  profileLabel: 'Ver perfil completo ›',
};
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  authorImage={authorImage}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  featuredProduct={featuredProduct}
>
  <p class="post-lead" id="introducao">
    Conteúdo do post em breve.
  </p>

  <h2 id="valor-pontos">Valor da multa e pontuação</h2>
  <p>Em breve.</p>

  <h2 id="ctb">O que diz o CTB</h2>
  <p>Em breve.</p>

  <h2 id="riscos">Riscos além da multa</h2>
  <p>Em breve.</p>

  <h2 id="conclusao">Conclusão</h2>
  <p>Em breve.</p>
</PostLayout>
