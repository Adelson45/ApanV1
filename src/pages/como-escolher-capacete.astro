const canonical = 'https://jovemapan.com.br/como-escolher-capacete/';
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  category="Reviews"
  categoryHref="/category/reviews/"
  publishDate="2026-01-01"
  author="Pamela Pan"
>
  <h2>Conteúdo em breve</h2>
  <p>Este post está sendo preparado. Em breve traremos a análise completa.</p>
</PostLayout>
