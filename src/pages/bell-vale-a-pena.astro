  <div class="btn-buy-container">
    <a href="https://amzn.to/4o5cuVD" class="btn-buy" target="_blank" rel="nofollow noopener noreferrer">Ver na Amazon</a>
    <a href="https://mercadolivre.com/sec/1FeAUM6" class="btn-buy ml" target="_blank" rel="nofollow noopener noreferrer">Ver no Mercado Livre</a>
  </div>
</div>

<h3 id="mx9-adventure">2. Capacete Bell Helmets MX-9 Adventure MIPS Matte</h3>

<div class="product-section">
