const indice = [
  { label: 'Capacetes até R$300 valem a pena?', href: '#valem' },
  { label: 'Top 10 capacetes até R$300', href: '#top10', children: [
    { label: '1. Pro Tork R8', href: '#protork-r8' },
    { label: '2. Pro Tork Evolution G6', href: '#evolution-g6' },
    { label: '3. Pro Tork New Liberty Three', href: '#liberty-three' },
    { label: '4. Pro Tork Evolution Evo', href: '#evolution-evo' },
    { label: '5. Pro Tork Sport Moto', href: '#sport-moto' },
    { label: '6. Pro Tork Automático SM', href: '#automatico-sm' },
    { label: '7. Pro Tork New Atomic Skull', href: '#atomic-skull' },
    { label: '8. Mixs Gladiator Neo', href: '#mixs-gladiator' },
    { label: '9. Mixs MX2 Storm', href: '#mixs-mx2' },
    { label: '10. Pro Tork New Liberty 3', href: '#liberty3' }
