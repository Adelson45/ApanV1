    features: [
      'Couro Tutu de alta qualidade',
      'Proteções de ombro em alumínio',
      'Proteções de cotovelo CE Nível 2',
      'Inserções elásticas para mobilidade',
      'Bolso para protetor de costas'
    ],
    pros: [
      'Proteção máxima de couro',
      'Acabamento premium italiano',
      'Design esportivo icônico',
      'Mobilidade apesar da proteção'
    ],
    cons: [
      'Preço premium',
      'Não é impermeável',
      'Quente em dias de calor',
      'Corte muito esportivo'
