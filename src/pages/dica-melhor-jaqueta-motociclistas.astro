  }
];

const materials = [
  {
    name: 'Couro',
    description: 'Máxima proteção contra abrasão. Ideal para uso esportivo e alta velocidade.',
    pros: ['Proteção superior', 'Durabilidade extrema', 'Estilo clássico'],
    cons: ['Preço elevado', 'Quente no verão', 'Manutenção necessária']
  },
  {
    name: 'Têxtil',
    description: 'Versátil e acessível. Opção mais popular para uso urbano e touring.',
    pros: ['Preço acessível', 'Leveza', 'Impermeável (geralmente)', 'Ventilação'],
    cons: ['Proteção inferior ao couro', 'Durabilidade menor', 'Troca a cada 3-5 anos']
  },
  {
    name: 'Mesh/Air Flow',
    description: 'Máxima ventilação para climas quentes. Proteção básica com conforto térmico.',
    pros: ['Ventilação máxima', 'Leveza', 'Conforto em calor'],
    cons: ['Proteção limitada', 'Sem isolamento térmico', 'Não é impermeável']
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Header />

  <main class="post-main">
    <div class="post-container">

      <!-- ==========================================
           1. CABEÇALHO (Breadcrumb, Título, Info)
           ========================================== -->
      <div class="post-header-section">
        <nav class="top-breadcrumb" aria-label="Breadcrumb">
          <a href="/">HOME</a>
          <span class="separator">›</span>
          <a href={categoryHref}>{category}</a>
          <span class="separator">›</span>
          <span class="current-page">Melhores Jaquetas 2026</span>
        </nav>

        <a href={categoryHref} class="post-category-tag">
          <svg class="icon" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
          {category}
        </a>

        <h1 class="post-title">Melhores Jaquetas para Motociclistas 2026: Guia de Proteção e Estilo</h1>

        <div class="post-meta-data">
          <div class="meta-author">
            <img src="/images/Pamela pan coufundadora e editoara chefe do blog apan .png" alt={author} class="author-avatar" onerror="this.src='https://ui-avatars.com/api/?name=Pamela+Pan&background=random'" />
            <strong>{author.toUpperCase()}</strong>
          </div>
          <div class="meta-info">
             <span class="meta-item">
               <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
               {publishDate}
             </span>
             <span class="meta-item">
               <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
               18K VIEWS
             </span>
             <span class="meta-item">
               <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
               12 COMMENTS
             </span>
          </div>
        </div>
      </div>

      <!-- ==========================================
           2. GRID PRINCIPAL (Col 1: Social | Col 2: Artigo | Col 3: Sidebar)
           ========================================== -->
      <div class="post-layout-grid">
        
        <!-- [ESQUERDA] Botões Sociais -->
        <div class="post-social-col">
          <div class="sticky-socials">
            <a href="https://www.facebook.com/profile.php?id=100088166945491" target="_blank" rel="noopener noreferrer" class="social-btn facebook" aria-label="Facebook">f</a>
            <a href="https://br.pinterest.com/jovemapan/" target="_blank" rel="noopener noreferrer" class="social-btn pinterest" aria-label="Pinterest">
              <svg viewBox="0 0 24 24" fill="white" width="18" height="18"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
            </a>
            <a href="https://www.youtube.com/channel/UCChj9-uIY5ERfidZ6K-zt_w" target="_blank" rel="noopener noreferrer" class="social-btn youtube" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="white" width="18" height="18"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
            <a href="https://www.instagram.com/jovem_apan/" target="_blank" rel="noopener noreferrer" class="social-btn instagram" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" width="14" height="14"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
          </div>
        </div>

        <!-- [CENTRO] Artigo -->
        <article class="post-content-col">
          
          <!-- Foto de Capa (Hero) com Selo Verified -->
          <div class="post-cover-image">
            <img src={coverImage} alt="Capa do Artigo" />
            <div class="verified-badge">
              <svg viewBox="0 0 24 24" width="12" height="12" stroke="var(--red)" stroke-width="3" fill="none"><polyline points="20 6 9 17 4 12"></polyline></svg>
              APAN VERIFIED
            </div>
          </div>

          <!-- Índice Modo Accordion -->
          <div class="post-indice" id="indice-accordion">
            <div class="indice-header" onclick="toggleIndice()">
              <div class="indice-left">
                <div class="indice-icon">
                  <svg viewBox="0 0 24 24" width="18" height="18" stroke="white" stroke-width="2" fill="none"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
                </div>
                <strong>ÍNDICE DE CONTEÚDO</strong>
              </div>
              <div class="indice-arrow" id="indice-arrow">
                <svg viewBox="0 0 24 24" width="16" height="16" stroke="var(--text-meta)" stroke-width="2" fill="none"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </div>
            </div>
            <div class="indice-content" id="indice-content">
              <ul class="indice-links">
                <li><a href="#introducao">Introdução</a></li>
                <li><a href="#materiais">Escolha o Material Ideal</a></li>
                <li><a href="#melhores-jaquetas">Melhores Jaquetas para Motociclistas 2026</a>
                  <ul>
                    <li><a href="#jaqueta-1">1. Alpinestars T-GP Plus R v3</a></li>
                    <li><a href="#jaqueta-2">2. X11 Iron Masc 2</a></li>
                    <li><a href="#jaqueta-3">3. Tutto Moto Tifon 2</a></li>
                    <li><a href="#jaqueta-4">4. Dainese Racing 3 Perforated</a></li>
                  </ul>
                </li>
                <li><a href="#protecoes">A Importância das Proteções</a></li>
                <li><a href="#conclusao">Conclusão</a></li>
              </ul>
            </div>
          </div>

          <!-- CONTEÚDO DO ARTIGO -->
          <div class="post-lead" id="introducao">
            <p>Escolher a jaqueta ideal é um passo crucial para qualquer motociclista que valoriza segurança e conforto. Seja para enfrentar o trânsito urbano, encarar estradas em alta velocidade ou lidar com as variações climáticas, o equipamento certo protege o corpo e melhora a experiência de pilotagem. Neste guia, analisamos as melhores opções de 2026.</p>
          </div>

          <h2 id="materiais">Escolha o Material Ideal</h2>
          <p>O material da jaqueta define não apenas o nível de proteção contra abrasão, mas também o conforto térmico e a durabilidade do equipamento.</p>
          
          <div class="materials-grid-container">
            {materials.map(material => (
              <div class="product-section">
                <h3>{material.name}</h3>
                <p>{material.description}</p>
                <div class="pros-cons-grid">
                  <div class="pc-col">
                    <h4 class="pros">Vantagens</h4>
                    <ul class="pc-list pros">
                      {material.pros.map(pro => <li>{pro}</li>)}
                    </ul>
                  </div>
                  <div class="pc-col">
                    <h4 class="cons">Desvantagens</h4>
                    <ul class="pc-list cons">
                      {material.cons.map(con => <li>{con}</li>)}
                    </ul>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <h2 id="melhores-jaquetas">Melhores Jaquetas para Motociclistas 2026</h2>
          <p>Abaixo, detalhamos os modelos que se destacam no mercado brasileiro pela qualidade, tecnologia e custo-benefício.</p>

          {jackets.map((jacket, index) => (
            <div id={`jaqueta-${index + 1}`}>
              <h3 id={`jaqueta-${index + 1}`}>{index + 1}. {jacket.name} {jacket.subtitle}</h3>
              <p>{jacket.description}</p>
              
              <div class="product-section">
                <div class="h2-image-card" style="margin-top: 0;">
                  <img src={jacket.image} alt={jacket.name} />
                </div>
                
                <div class="sidebar-widget" style="background: var(--gray-light); margin-bottom: 24px; padding: 15px; border-radius: 8px; border: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
                  <span style="font-weight: 800; color: var(--red);">{jacket.price}</span>
                  <span style="font-weight: 800; color: var(--black);">★ {jacket.rating}</span>
                </div>

                <h4>Principais Características:</h4>
                <ul>
                  {jacket.features.map(f => <li>{f}</li>)}
                </ul>

                <div class="pros-cons-grid">
                  <div class="pc-col">
                    <h4 class="pros">Prós</h4>
                    <ul class="pc-list pros">
                      {jacket.pros.map(p => <li>{p}</li>)}
                    </ul>
                  </div>
                  <div class="pc-col">
                    <h4 class="cons">Contras</h4>
                    <ul class="pc-list cons">
                      {jacket.cons.map(c => <li>{c}</li>)}
                    </ul>
                  </div>
                </div>

                <div class="btn-buy-container" style="margin-top: 32px;">
                  <a href={jacket.affiliateLink} target="_blank" rel="nofollow noopener" class="btn-buy">Ver Preço na Amazon</a>
                </div>
              </div>
            </div>
          ))}

          <h2 id="protecoes">🛡️ A Importância das Proteções</h2>
          <p>Uma jaqueta de moto adequada pode fazer a diferença entre ferimentos leves e lesões graves em caso de queda. Não se deixe enganar apenas pelo visual; confira o que é essencial:</p>
          
          <div class="product-section">
            <ul>
              <li><strong>Proteções de Ombro:</strong> Absorvem impactos nas quedas laterais e protegem uma das áreas mais vulneráveis.</li>
              <li><strong>Proteções de Cotovelo:</strong> Essenciais, pois o reflexo natural em quedas é apoiar-se nos cotovelos.</li>
              <li><strong>Protetor de Costas:</strong> Protege a coluna vertebral contra impactos diretos. Recomendado certificação CE Nível 2.</li>
              <li><strong>Resistência à Abrasão:</strong> O tecido deve resistir ao deslizamento no asfalto. Couro oferece a maior proteção, seguido por Cordura e Poliéster de alta densidade.</li>
            </ul>
          </div>

          <h2 id="conclusao">Conclusão: Qual jaqueta escolher?</h2>
          <p>A escolha final depende do seu uso predominante. Para viagens e uso esportivo, o couro continua imbatível. Para o dia a dia urbano, as jaquetas têxteis como a X11 Iron oferecem o melhor equilíbrio entre proteção e praticidade.</p>
          <p>Sempre verifique o tamanho correto e certifique-se de que as proteções fiquem posicionadas exatamente sobre as articulações.</p>
          <p>Pronto para completar seu kit? Veja também nossas análises de <a href="/melhor-capacete/luvas/">melhores luvas</a> e <a href="/melhor-capacete/">melhores capacetes</a>.</p>

          <!-- TAGS E COMPARTILHAMENTO -->
          <div class="post-footer-meta">
            <div class="post-tags-container">
              <strong>TAGS:</strong>
              <div class="post-tags">
                <a href="/category/dicas/" class="post-tag">Dicas</a>
                <a href="#" class="post-tag">Jaquetas</a>
                <a href="#" class="post-tag">Equipamentos</a>
                <a href="#" class="post-tag">Segurança</a>
                <a href="#" class="post-tag">2026</a>
              </div>
            </div>
          </div>

          <div class="post-share-container">
            <strong>COMPARTILHE ESTE ARTIGO:</strong>
            <div class="post-share">
              <a href="https://www.facebook.com/sharer/sharer.php?u=https://jovemapan.com.br/dica-melhor-jaqueta-motociclistas/" target="_blank" rel="noopener noreferrer" class="share-btn facebook" aria-label="Facebook">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="white"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                Facebook
              </a>
              <a href="https://twitter.com/intent/tweet?url=https://jovemapan.com.br/dica-melhor-jaqueta-motociclistas/&text=Melhores%20Jaquetas%20para%20Motociclistas%202026" target="_blank" rel="noopener noreferrer" class="share-btn twitter" aria-label="Twitter">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="white"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
                Twitter
              </a>
              <a href="#" onclick="navigator.clipboard.writeText('https://jovemapan.com.br/dica-melhor-jaqueta-motociclistas/'); alert('Link copiado!'); return false;" class="share-btn link" aria-label="Copiar Link">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="#666"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                Link
              </a>
            </div>
          </div>

          <!-- BIO DO AUTOR -->
          <div class="author-bio-box" id="author">
            <div class="bio-avatar">
              <img src="/images/Pamela pan coufundadora e editoara chefe do blog apan .png" alt="Pamela Pan" onerror="this.src='https://ui-avatars.com/api/?name=Pamela+Pan&background=random'" />
            </div>
            <div class="bio-content">
              <h4 class="bio-name">Pamela Pan</h4>
              <p class="bio-desc">
                Cofundadora e Editora-chefe do Blog Apan, especializada em trazer as melhores análises e tendências do mundo das duas rodas.
              </p>
              <a href="/author-pamela-pan/" class="bio-link">SOBRE A AUTORA →</a>
            </div>
          </div>

          <!-- SEÇÃO DE COMENTÁRIOS -->
          <div class="post-comments-section" id="comments">
            <h3 class="comments-title">COMENTÁRIOS</h3>
            <p class="comments-note">Seu endereço de email não será publicado.</p>
            
