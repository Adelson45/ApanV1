---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Review Completo do Capacete Texx';
const description = 'Análise completa dos capacetes Texx. Marca brasileira, qualidade e modelos para todos os perfis.';
const canonical = 'https://jovemapan.com.br/review-capacete-texx/';
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  category="Reviews"
  categoryHref="/category/reviews/"
  publishDate="2026-01-01"
  author="Pamela Pan"
>
  <h2>Conteúdo em breve</h2>
  <p>Este post está sendo preparado. Em breve traremos a análise completa.</p>
</PostLayout>
