---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Paula Becker | Especialista em Equipamentos e Lifestyle Jovem Apan';
const description = 'Paula Becker é a mente analítica e cuidadosa por trás dos conteúdos mais completos do Jovem Apan. Com olhar técnico e foco em precisão.';

const authorBio = {
  name: 'Paula Becker',
  description: 'Redatora & Especialista em equipamentos e lifestyle, focada em segurança e usabilidade.',
  image: '/images/Ana%20paula%20editora%20do%20blog%20apan%20.png',
  profileHref: '/author-paula-becker/',
  profileLabel: 'Ver perfil completo ›'
};

const indice = [
  { label: 'Bio', href: '#introducao' },
  { label: 'Destaques', href: '#destaques' },
  { label: 'Experiência', href: '#experiencia' },
  { label: 'Educação', href: '#educacao' },
];
---

<PostLayout
  title={title}
  description={description}
  category="EQUIPE"
  author="Paula Becker"
  authorBio={authorBio}
  coverImage="/images/Ana%20paula%20editora%20do%20blog%20apan%20.png"
  indice={indice}
  hideShare={true}
  hideAuthor={true}
  hideComments={true}
>
  <div class="author-profile-header" id="introducao">
    <div class="author-photo">
      <img src="/images/Ana%20paula%20editora%20do%20blog%20apan%20.png" alt="Paula Becker" />
    </div>
    <span class="author-role">Redatora Especialista</span>
    <h1 class="author-name">Paula Becker</h1>
    <div class="author-title">
      <span class="icon">🔍</span> Especialista em Equipamentos e Lifestyle
    </div>
    <p class="author-intro-text">
      Paula Becker é a mente analítica e cuidadosa por trás dos conteúdos mais completos do Jovem Apan. Com olhar técnico, foco em precisão e paixão por segurança no motociclismo, ela é referência interna quando o assunto é transformar dados, testes e experiências reais em artigos confiáveis e fáceis de entender.
    </p>
  </div>

  <h2 id="destaques">Destaques</h2>
  <div class="highlights-grid">
    <div class="highlight-card">
      <div class="highlight-icon">🎯</div>
      <h3>Especialista em Equipamentos</h3>
      <p>Especialista em equipamentos de proteção e lifestyle motociclístico, com habilidade em unir análise técnica com linguagem acessível.</p>
    </div>
    <div class="highlight-card">
      <div class="highlight-icon">👁️</div>
      <h3>Olhar Atento para Tendências</h3>
      <p>Olhar atento para tendências, segurança e usabilidade de acessórios, com forte compromisso com a qualidade, imparcialidade e profundidade das reviews.</p>
    </div>
    <div class="highlight-card">
      <div class="highlight-icon">📝</div>
      <h3>Curadoria de Produtos</h3>
      <p>Referência no blog em pesquisas, validação de informações e curadoria de produtos para motociclistas de todos os níveis.</p>
    </div>
    <div class="highlight-card">
      <div class="highlight-icon">🤝</div>
      <h3>Compromisso com Qualidade</h3>
      <p>Forte compromisso com a qualidade, imparcialidade e profundidade das reviews. Cada artigo é resultado de pesquisa meticulosa.</p>
    </div>
  </div>

  <h2 id="experiencia">Experiência</h2>
  <div class="timeline">
    <div class="timeline-item">
      <h3>Redatora e Especialista em Equipamentos</h3>
      <p><strong>Jovem Apan</strong></p>
      <p>Responsável por aprofundar temas relacionados a vestuário, acessórios, conforto e segurança no motociclismo. Conduz pesquisas, compara modelos, testa funcionalidades e traduz toda essa complexidade em artigos claros e confiáveis.</p>
    </div>
    <div class="timeline-item">
      <h3>Colaboradora em Plataformas de Lifestyle</h3>
      <p><strong>Reviews de Produtos</strong></p>
      <p>Colaborou com plataformas de lifestyle e reviews de produtos, sempre reconhecida por sua escrita precisa, didática e orientada a soluções práticas.</p>
    </div>
  </div>

  <h2 id="educacao">Educação</h2>
  <ul class="education-list">
    <li><strong>Comunicação Social:</strong> Foco em análise de conteúdo e comportamento do usuário.</li>
    <li><strong>Cursos complementares:</strong> Segurança veicular, metodologia de testes de produtos e UX Writing.</li>
    <li><strong>Certificações:</strong> Pesquisa aplicada e redação técnica.</li>
  </ul>

  <blockquote class="author-quote">
    <p>"Minha missão no blog é simples e poderosa: ajudar motociclistas a fazer escolhas melhores com segurança, conhecimento e autenticidade."</p>
    <cite>— Paula Becker</cite>
  </blockquote>
</PostLayout>

<style>
  .author-profile-header {
    text-align: center;
    background: #fff;
    border: 1px solid #eee;
    border-radius: 24px;
    padding: 60px 40px;
    margin-bottom: 40px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .author-photo {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    border: 4px solid #e31b1b;
    padding: 10px;
    margin-bottom: 25px;
    background: #fff;
    box-shadow: 0 10px 40px rgba(227, 27, 27, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .author-photo:hover {
    transform: scale(1.02);
  }

  .author-photo img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
  }

  .author-role {
    font-size: 1rem;
    color: #666;
    font-weight: 400;
    margin-bottom: 12px;
    display: block;
  }

  .author-name {
    font-size: 2.5rem;
    font-weight: 800;
    color: #e31b1b;
    margin-bottom: 10px;
  }

  .author-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #333;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
  }

  .author-intro-text {
    font-size: 1.05rem;
    color: #555;
    line-height: 1.8;
    max-width: 700px;
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin: 30px 0;
  }
  .highlight-card {
    background: #fdfdfd;
    border: 1px solid #eee;
    border-radius: 16px;
    padding: 24px;
  }
  .highlight-icon { font-size: 2rem; margin-bottom: 10px; }
  .highlight-card h3 { font-size: 1.1rem; margin-bottom: 8px; }
  
  .timeline-item {
    margin-bottom: 24px;
    padding-left: 20px;
    border-left: 3px solid #e31b1b;
  }
  
  .author-quote {
    background: #fafafa;
    border-left: 4px solid #e31b1b;
    padding: 20px 30px;
    margin: 40px 0;
    font-style: italic;
  }
  
  @media (max-width: 768px) {
    .highlights-grid { grid-template-columns: 1fr; }
    .author-name { font-size: 2rem; }
  }
</style>


