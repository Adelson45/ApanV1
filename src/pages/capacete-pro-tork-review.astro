---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Review da Marca Pro Tork';
const description = 'Análise completa da marca Pro Tork: principais modelos, qualidade e custo-benefício em 2026.';
const canonical = 'https://jovemapan.com.br/capacete-pro-tork-review/';
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  category="Reviews"
  categoryHref="/category/reviews/"
  publishDate="2026-01-01"
  author="Pamela Pan"
>
  <h2>Conteúdo em breve</h2>
  <p>Este post está sendo preparado. Em breve traremos a análise completa.</p>
</PostLayout>
