    <section class="reviews-section">
      <div class="container">
        <div class="reviews-layout">
          <!-- Main Content -->
          <div class="reviews-main" id="reviews-main">
            {allReviews.map((review, i) => (
              <article class="review-card" data-index={i}>
                <a href={review.href} class="review-title-link">
                  <h2 class="review-title">{review.title}</h2>
                </a>
                <p class="review-date">{review.date}</p>
                <div class="review-body">
                  <a href={review.href} class="review-thumb">
                    {review.image ? (
                      <img src={review.image} alt={review.title} loading="lazy" />
                    ) : (
                      <div class="thumb-placeholder">
                        <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="#aaa" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><path d="m21 15-5-5L5 21"></path></svg>
                      </div>
                    )}
                  </a>
                  <div class="review-text">
                    <p class="review-excerpt">{review.excerpt}</p>
                    <a href={review.href} class="read-more-btn">Leia mais</a>
                  </div>
                </div>
