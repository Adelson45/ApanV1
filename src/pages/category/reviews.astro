<script is:inline>
  const PER_PAGE = 10;
  let currentPage = 1;
  const cards = document.querySelectorAll('.review-card');
  const totalPages = Math.ceil(cards.length / PER_PAGE);
  const paginationEl = document.getElementById('pagination');

  function showPage(page) {
    currentPage = page;
    const start = (page - 1) * PER_PAGE;
    const end = start + PER_PAGE;

    cards.forEach((card, i) => {
      card.style.display = (i >= start && i < end) ? '' : 'none';
    });

    renderPagination();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function renderPagination() {
    let html = '';

    // Anterior
    if (currentPage > 1) {
      html += '<a href="#" class="pg-btn pg-arrow" data-page="' + (currentPage - 1) + '">‹ Anterior</a>';
    }

    // Page numbers
    for (let i = 1; i <= totalPages; i++) {
      if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
        html += '<a href="#" class="pg-btn' + (i === currentPage ? ' pg-active' : '') + '" data-page="' + i + '">' + i + '</a>';
      } else if (i === currentPage - 2 || i === currentPage + 2) {
        html += '<span class="pg-dots">…</span>';
      }
    }

    // Próximo
    if (currentPage < totalPages) {
      html += '<a href="#" class="pg-btn pg-arrow" data-page="' + (currentPage + 1) + '">Proxímo ›</a>';
    }

    paginationEl.innerHTML = html;

    // Bind clicks
    paginationEl.querySelectorAll('.pg-btn').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        showPage(parseInt(this.dataset.page));
      });
    });
  }

  showPage(1);
</script>
</Layout>

<style>
  :root {
    --red: #E31E24;
    --red-dark: #C41A1F;
    --black: #000000;
    --gray-bg: #F4F4F4;
    --border: #EAEAEA;
    --text: #374151;
    --text-meta: #777;
    --white: #ffffff;
    --font-primary: 'Inter', ui-sans-serif, system-ui, sans-serif;
  }

  /* Breadcrumb */
  .breadcrumb-section {
    background: var(--white);
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-meta);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .breadcrumb a {
    color: var(--text-meta);
    text-decoration: none;
    transition: color 0.2s;
  }
  .breadcrumb a:hover {
    color: var(--red);
  }
  .breadcrumb .current {
    color: var(--red);
  }
  .breadcrumb .sep {
    color: #ccc;
  }

  /* Page Title */
  .page-title-section {
    background: var(--white);
    padding: 40px 0 30px;
    border-bottom: 3px solid var(--red);
  }
  .page-title-section h1 {
    font-family: var(--font-primary);
    font-size: 2.4rem;
    font-weight: 900;
    color: var(--black);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: -0.5px;
  }

  /* Container */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Reviews Section */
  .reviews-section {
    background: var(--gray-bg);
    padding: 40px 0 80px;
  }

  .reviews-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 40px;
    align-items: start;
  }

  /* Review Cards */
  .reviews-main {
    display: flex;
    flex-direction: column;
    gap: 24px;
    min-width: 0;
  }

  .review-card {
    background: var(--white);
    padding: 24px 20px 28px;
    border-bottom: 3px solid var(--border);
  }
  .review-card:last-child {
    border-bottom: none;
  }

  .review-title-link {
    text-decoration: none;
  }

  .review-title {
    font-family: var(--font-primary);
    font-size: 1.35rem;
    font-weight: 700;
    color: #1a1a2e;
    margin: 0 0 4px;
    line-height: 1.35;
    transition: color 0.2s;
  }
  .review-title-link:hover .review-title {
    color: #2563EB;
  }

  .review-date {
    font-size: 0.8rem;
    color: var(--text-meta);
    font-weight: 500;
    margin: 0 0 14px;
  }

  /* Two-column body: image left, text right */
  .review-body {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .review-thumb {
    flex-shrink: 0;
    width: 180px;
    height: 130px;
    display: block;
    border-radius: 6px;
    overflow: hidden;
    background: #f4f4f4;
  }
  .review-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .thumb-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e8eaf0 0%, #d1d5db 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
  }

  .review-text {
    flex: 1;
    min-width: 0;
  }

  .review-excerpt {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text);
    margin: 0 0 14px;
  }

  .read-more-btn {
    display: inline-block;
    padding: 8px 20px;
