---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Limpeza do Capacete: Guia Completo para Cuidar do Seu Equipamento';
const description = 'Como limpar o capacete por dentro e por fora sem danificar materiais. Produtos certos, frequência ideal e dicas para tirar cheiro e sujeira do forro.';
const canonical = 'https://jovemapan.com.br/limpeza-do-capacete/';
const author = 'Marcelo Ferreira';
const authorImage = '/images/marcelo-ferreira.png';
const publishDate = '2026-04-23';
const category = 'Dicas';
const categoryHref = '/category/dicas/';
const coverImage = '/images/moto-shop-cover.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. Limpeza externa', href: '#externa' },
  { label: '3. Limpeza do forro interno', href: '#interno' },
  { label: '4. Limpeza da viseira', href: '#viseira' },
  { label: '5. Conclusão', href: '#conclusao' },
];

const tags = [
  { label: 'LIMPEZA', href: '#' },
  { label: 'MANUTENÇÃO', href: '#' },
  { label: 'DICAS', href: '/category/dicas/' },
  { label: '2026', href: '#' },
];

const featuredProduct = {
  preTitle: 'APROVEITE FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete Shoei Premium Edition',
  name: 'Capacete Shoei<br/>Premium Edition',
  mercadoLivreHref: '#',
  amazonHref: '#',
};

const authorBio = {
  name: author,
  description: 'Redator & Editor especializado em transformar especificações técnicas complexas em conteúdo claro, envolvente e acessível.',
  image: authorImage,
  profileHref: '/author-marcelo-ferreira/',
  profileLabel: 'Ver perfil completo ›',
};
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  authorImage={authorImage}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  featuredProduct={featuredProduct}
>
  <p class="post-lead" id="introducao">
    Conteúdo do post em breve.
  </p>

  <h2 id="externa">Limpeza externa</h2>
  <p>Em breve.</p>

  <h2 id="interno">Limpeza do forro interno</h2>
  <p>Em breve.</p>

  <h2 id="viseira">Limpeza da viseira</h2>
  <p>Em breve.</p>

  <h2 id="conclusao">Conclusão</h2>
  <p>Em breve.</p>
</PostLayout>
