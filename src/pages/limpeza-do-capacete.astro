const description = 'Aprenda como limpar e manter seu capacete de motocicleta em 10 etapas. Materiais, cuidados com viseira, Pinlock, eletrônicos e remontagem segura.';
const canonical = 'https://jovemapan.com.br/limpeza-do-capacete/';
