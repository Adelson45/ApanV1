const authorImage = '/images/Pamela pan coufundadora e editoara chefe do blog apan .png';
const publishDate = '2026-04-23';
const category = 'Dicas';
const categoryHref = '/category/dicas/';
const coverImage = '/images/tire-a-viseira-do-capacete-da-forma-correta.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. Materiais de limpeza', href: '#materiais' },
  { label: '3. Remova eletrônicos', href: '#eletronicos' },
  { label: '4. Remova o interior', href: '#interior' },
  { label: '5. Prepare a estrutura externa', href: '#externa' },
  { label: '6. Limpe o revestimento interno', href: '#interno' },
  { label: '7. Limpe o exterior', href: '#exterior' },
  { label: '8. Limpe as aberturas', href: '#aberturas' },
  { label: '9. Limpe a viseira', href: '#viseira' },
  { label: '10. Limpe o protetor solar', href: '#protetor-solar' },
  { label: '11. Remonte o capacete', href: '#remontar' },
];

const tags = [
  { label: 'LIMPEZA', href: '#' },
  { label: 'MANUTENÇÃO', href: '#' },
  { label: 'DICAS', href: '/category/dicas/' },
  { label: 'CAPACETE', href: '/melhor-capacete/' },
  { label: '2026', href: '#' },
];

const featuredProduct = {
  preTitle: 'APROVEITE FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete Shoei Premium Edition',
  name: 'Capacete Shoei<br/>Premium Edition',
  mercadoLivreHref: '#',
  amazonHref: '#',
};

const authorBio = {
  name: author,
  description: 'Cofundadora e Editora-chefe do Blog Apan, especializada em trazer as melhores análises e tendências do mundo das duas rodas.',
  image: authorImage,
