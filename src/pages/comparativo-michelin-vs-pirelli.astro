---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Comparativo Michelin vs Pirelli: Qual Pneu de Moto É Melhor?';
const description = 'Comparativo detalhado entre pneus Michelin e Pirelli para moto. Aderência, durabilidade, preço e qual escolher para o seu tipo de uso em 2026.';
const canonical = 'https://jovemapan.com.br/comparativo-michelin-vs-pirelli/';
const author = 'Marcelo Ferreira';
const authorImage = '/images/marcelo-ferreira.png';
const publishDate = '2026-04-23';
const category = 'Comparativos';
const categoryHref = '/category/reviews/';
const coverImage = '/images/moto-shop-cover.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. Michelin: características principais', href: '#michelin' },
  { label: '3. Pirelli: características principais', href: '#pirelli' },
  { label: '4. Comparativo direto', href: '#comparativo' },
  { label: '5. Conclusão', href: '#conclusao' },
];

const tags = [
  { label: 'COMPARATIVO', href: '#' },
  { label: 'MICHELIN', href: '#' },
  { label: 'PIRELLI', href: '#' },
  { label: 'PNEUS', href: '#' },
];

const featuredProduct = {
  preTitle: 'APROVEITE FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete Shoei Premium Edition',
  name: 'Capacete Shoei<br/>Premium Edition',
  mercadoLivreHref: '#',
  amazonHref: '#',
};

const authorBio = {
  name: author,
  description: 'Redator & Editor especializado em transformar especificações técnicas complexas em conteúdo claro, envolvente e acessível.',
  image: authorImage,
  profileHref: '/author-marcelo-ferreira/',
  profileLabel: 'Ver perfil completo ›',
};
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  authorImage={authorImage}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  featuredProduct={featuredProduct}
>
  <p class="post-lead" id="introducao">
    Conteúdo do post em breve.
  </p>

  <h2 id="michelin">Michelin: características principais</h2>
  <p>Em breve.</p>

  <h2 id="pirelli">Pirelli: características principais</h2>
  <p>Em breve.</p>

  <h2 id="comparativo">Comparativo direto</h2>
  <p>Em breve.</p>

  <h2 id="conclusao">Conclusão</h2>
  <p>Em breve.</p>
</PostLayout>
