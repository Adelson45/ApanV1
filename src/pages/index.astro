    pros: [
      'Aerodinâmica Avançada - Desenvolvido com pilotos profissionais e testado em túnel de vento',
      'Ventilação Superior - 6 entradas e 6 saídas de ar, sistema de resfriamento nas bochechas',
      'Conforto Personalizado - Almofadas Max-Dry removíveis, laváveis e ajustáveis'
    ],
    contras: [
      'Preço Elevado - A partir de R$ 5.999,90, um dos mais caros do mercado',
      'Peso Relativamente Alto - Pode causar desconforto em uso prolongado',
      'Design Específico para Uso Esportivo - Não ideal para uso urbano diário'
    ]
  },
  {
    nome: 'Capacetes Bell Qualifier Forced Air Street',
    imagem: '/images/apacete bell.png',
    linkAfiliado: 'https://amzn.to/4jiQnJp',
    pros: [
      'Ventilação Forçada e Isolamento de Poeira - Sistema que mantém o interior fresco e limpo',
      'Compatibilidade com Sistemas de Comunicação - Bolsos internos para alto-falantes Sena e Cardo',
      'Conforto e Ajuste Personalizado - Interior removível, lavável e antibacteriano com sistema Ionic+'
    ],
    contras: [
      'Peso Relativamente Alto - Aproximadamente 1.727g no tamanho M',
      'Ruído em Altas Velocidades - Pode ser barulhento devido à ventilação',
      'Preço Elevado - Modelo especializado com preço superior aos convencionais'
    ]
  }
];

const categoriasCapacetes = [
  { nome: 'Capacetes para Motos', href: '/melhor-capacete/', imagem: '/images/capacete moto -shark-preto.png' },
  { nome: 'Capacetes para Bicicleta', href: '/melhor-capacete-para-bike/', imagem: '/images/capacete-para-bicicletas-bike.png' },
  { nome: 'Capacetes para Skates', href: '/melhor-capacete-para-skate/', imagem: '/images/Capacete-de-skate.png' },
  { nome: 'Capacete para Futebol', href: 'https://amzn.to/4w3CRQv', imagem: '/images/Capacete-de-futebol-esportivo.png', external: true },
  { nome: 'Capacete para Ski', href: 'https://amzn.to/4mZwjhA', imagem: '/images/Capacete-de-esqui-Ledge-MIPS-1.png', external: true },
  { nome: 'Capacete para Boxe', href: 'https://amzn.to/42CelIG', imagem: '/images/capacete-chapeu-de-boxe-com-bochechas.png', external: true }
