---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const categories = [
  {
    title: 'Capacetes de Moto',
    description: 'Reviews completos dos melhores capacetes para motociclistas, com foco em segurança, conforto e estilo.',
    image: '/images/capacete-moto.jpg',
    href: '/capacetes-moto'
  },
  {
    title: 'Capacetes de Bike',
    description: 'Análises detalhadas de capacetes para ciclismo, mountain bike e bicicletas urbanas.',
    image: '/images/capacete-bike.jpg',
    href: '/capacetes-bike'
  },
  {
    title: 'Capacetes Infantis',
    description: 'Os melhores capacetes para crianças, com segurança certificada e designs divertidos.',
    image: '/images/capacete-infantil.jpg',
    href: '/capacetes-infantil'
  }
];

const featuredReviews = [
  {
    title: 'Capacete AGV K-3 SV',
    category: 'Moto',
    rating: 4.8,
    image: '/images/agv-k3-sv.jpg',
    excerpt: 'Excelente custo-benefício com ventilação superior e ótima aerodinâmica.',
    href: '/reviews/agv-k3-sv'
  },
  {
    title: 'Capacete LS2 FF320',
    category: 'Moto',
    rating: 4.7,
    image: '/images/ls2-ff320.jpg',
    excerpt: 'Capacete versátil com ótima relação custo-benefício e acabamento premium.',
    href: '/reviews/ls2-ff320'
  },
  {
    title: 'Capacete Troy Lee Designs',
    category: 'Bike',
    rating: 4.9,
    image: '/images/troy-lee-designs.jpg',
    excerpt: 'Referência em capacetes de downhill com proteção máxima.',
    href: '/reviews/troy-lee-designs'
  }
];
---

<Layout>
  <Header />
  
  <main>
    <!-- Hero Section -->
    <section class="hero" aria-label="Introdução">
      <div class="hero-content">
        <h1>Reviews de Capacetes para Moto, Bike e Mais</h1>
        <p class="hero-subtitle">
          Análises completas e imparciais dos melhores capacetes do mercado. 
          Comparativos, avaliações de usuários e dicas para escolher o modelo ideal.
        </p>
        <div class="hero-cta">
          <a href="#categorias" class="btn btn-primary">Explorar Reviews</a>
          <a href="/guia-de-compra" class="btn btn-secondary">Guia de Compra</a>
        </div>
      </div>
    </section>
    
    <!-- Categories Section -->
    <section id="categorias" class="categories-section" aria-labelledby="categories-heading">
      <div class="container">
        <h2 id="categories-heading" class="section-title">Escolha sua Categoria</h2>
        <div class="categories-grid">
          {categories.map(category => (
            <article class="category-card">
              <a href={category.href} class="category-link">
                <div class="category-image">
                  <img src={category.image} 
                       alt={category.title} 
                       width="400" 
                       height="250" 
                       loading="lazy" />
                </div>
                <div class="category-content">
                  <h3>{category.title}</h3>
                  <p>{category.description}</p>
                  <span class="category-cta">Ver reviews →</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
    
    <!-- Featured Reviews -->
    <section class="featured-section" aria-labelledby="featured-heading">
      <div class="container">
        <h2 id="featured-heading" class="section-title">Reviews em Destaque</h2>
        <div class="reviews-grid">
          {featuredReviews.map(review => (
            <article class="review-card">
              <a href={review.href} class="review-link">
                <div class="review-image">
                  <img src={review.image} 
                       alt={review.title} 
                       width="350" 
                       height="220" 
                       loading="lazy" />
                  <span class="review-badge">{review.category}</span>
                </div>
                <div class="review-content">
                  <div class="review-rating" aria-label={`Avaliação: ${review.rating} de 5 estrelas`}>
                    {'★'.repeat(Math.floor(review.rating))}
                    {review.rating % 1 !== 0 && '½'}
                    <span class="rating-number">{review.rating}</span>
                  </div>
                  <h3>{review.title}</h3>
                  <p>{review.excerpt}</p>
                  <span class="read-more">Ler review completo →</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
    
    <!-- Newsletter Section -->
    <section class="newsletter-section" aria-labelledby="newsletter-heading">
      <div class="container">
        <div class="newsletter-content">
          <h2 id="newsletter-heading">Receba as Melhores Ofertas</h2>
          <p>Cadastre-se para receber alertas de promoções e novos reviews diretamente no seu e-mail.</p>
          <form class="newsletter-form" action="/api/subscribe" method="POST">
            <label for="email" class="visually-hidden">Seu e-mail</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              placeholder="Digite seu e-mail" 
              required 
              aria-required="true"
            />
            <button type="submit" class="btn btn-primary">Cadastrar</button>
          </form>
          <p class="privacy-note">
            Ao cadastrar, você concorda com nossa <a href="/politica-de-privacidade">Política de Privacidade</a>.
          </p>
        </div>
      </div>
    </section>
  </main>
  
  <Footer showSocial={false} />
</Layout>

<style>
  /* Hero Section */
  .hero {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    color: #fff;
    padding: 100px 20px;
    text-align: center;
  }
  
  .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 20px;
  }
  
  .hero-subtitle {
    font-size: 1.25rem;
    color: #b0b0b0;
    margin-bottom: 30px;
    line-height: 1.6;
  }
  
  .hero-cta {
    display: flex;
    gap: 15px;
    justify-content: center;
    flex-wrap: wrap;
  }
  
  .btn {
    display: inline-block;
    padding: 15px 30px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
  }
  
  .btn-primary {
    background-color: #e31b1b;
    color: #fff;
  }
  
  .btn-primary:hover {
    background-color: #c41818;
  }
  
  .btn-secondary {
    background-color: transparent;
    color: #fff;
    border: 2px solid #fff;
  }
  
  .btn-secondary:hover {
    background-color: #fff;
    color: #1a1a2e;
  }
  
  /* Container */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  
  /* Section Title */
  .section-title {
    font-size: 2.5rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 50px;
    color: #212121;
  }
  
  /* Categories Section */
  .categories-section {
    padding: 80px 0;
    background-color: #fafafa;
  }
  
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 30px;
  }
  
  .category-card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .category-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
  }
  
  .category-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  
  .category-image {
    aspect-ratio: 16/10;
    overflow: hidden;
  }
  
  .category-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  
  .category-card:hover .category-image img {
    transform: scale(1.05);
  }
  
  .category-content {
    padding: 25px;
  }
  
  .category-content h3 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: #212121;
  }
  
  .category-content p {
    color: #666;
    line-height: 1.6;
    margin-bottom: 15px;
  }
  
  .category-cta {
    color: #e31b1b;
    font-weight: 600;
  }
  
  /* Featured Section */
  .featured-section {
    padding: 80px 0;
    background-color: #fff;
  }
  
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
  }
  
  .review-card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: rgba(23, 43, 99, 0.2) 0 7px 28px;
    transition: transform 0.3s ease;
  }
  
  .review-card:hover {
    transform: translateY(-5px);
  }
  
  .review-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  
  .review-image {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }
  
  .review-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .review-badge {
    position: absolute;
    top: 15px;
    left: 15px;
    background-color: #e31b1b;
    color: #fff;
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
  }
  
  .review-content {
    padding: 25px;
  }
  
  .review-rating {
    color: #ffc107;
    font-size: 1.1rem;
    margin-bottom: 10px;
  }
  
  .rating-number {
    color: #666;
    margin-left: 5px;
  }
  
  .review-content h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 10px;
    color: #212121;
  }
  
  .review-content p {
    color: #666;
    line-height: 1.6;
    margin-bottom: 15px;
  }
  
  .read-more {
    color: #e31b1b;
    font-weight: 600;
  }
  
  /* Newsletter Section */
  .newsletter-section {
    padding: 80px 0;
    background-color: #f7f8f9;
  }
  
  .newsletter-content {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }
  
  .newsletter-content h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 15px;
    color: #212121;
  }
  
  .newsletter-content > p {
    color: #666;
    margin-bottom: 30px;
  }
  
  .newsletter-form {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
  }
  
  .newsletter-form input {
    flex: 1;
    padding: 15px 20px;
    border: 2px solid #ddd;
    border-radius: 8px;
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }
  
  .newsletter-form input:focus {
    outline: none;
    border-color: #e31b1b;
  }
  
  .privacy-note {
    font-size: 0.875rem;
    color: #878787;
  }
  
  .privacy-note a {
    color: #e31b1b;
    text-decoration: none;
  }
  
  /* Visually Hidden */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  
  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: 60px 20px;
    }
    
    .section-title {
      font-size: 2rem;
    }
    
    .newsletter-form {
      flex-direction: column;
    }
    
    .newsletter-form .btn {
      width: 100%;
    }
  }
</style>
