const postsMaisVistos = [
  { titulo: 'Intercomunicador Cardo Review', href: '/intercomunicador-cardo-review/', imagem: '/images/Intercomunicador-Cardo-Spirit%20.png', categoria: 'REVIEWS' },
  { titulo: 'Comparativo Michelin vs Pirelli', href: '/comparativo-michelin-vs-pirelli/', imagem: '/images/Comparação-pneu-pirelli-versos-michelin.png', categoria: 'REVIEWS' },
  { titulo: 'Michelin Pilot Street Review', href: '/michelin-pilot-street-review/', imagem: '/images/pneu-michelin-pilot-street.png', categoria: 'REVIEWS' },
  { titulo: 'Pirelli Super City Review', href: '/pirelli-super-city-review/', imagem: '/images/seis-Pneus-de-moto-novos-em-uma-oficina-mecanca.png', categoria: 'REVIEWS' },

  { titulo: 'Melhores pneus para CG160', href: '/melhores-pneus-para-cg160/', imagem: '/images/Borracheiro-em-uma-oficina-fazento-uma-troca-de-pneu-de-moto.png', categoria: 'REVIEWS' },
  { titulo: 'Comparativo Jaqueta Texx vs X11', href: '/comparativo-jaqueta-texx-vs-x11/', imagem: '/images/Jaqueta-de-motociclista-da-marca-texx-e-uma-da-marca-x11.webp', categoria: 'REVIEWS' },
  { titulo: 'Melhor Capacete HJC Helmets', href: '/melhor-capacete-hjc-helmets/', imagem: '/images/melhores%20capacete%20hjc%20helmets.png', categoria: 'CAPACETES' },
  { titulo: 'Melhores Cadeados para Moto', href: '/cadeados-para-moto/', imagem: '/images/Melhores-Cadeados-para-Moto-e-bike.png', categoria: 'DICAS' },

  { titulo: 'Análise Intercomunicador Ejeas V6', href: '/intercomunicador-ejeas-review/', imagem: '/images/dois motociclistas viajando na estrada com suas motos conectados com Intercomunicador Capacete V6  Bluetooth Comunicador.png', categoria: 'REVIEWS' },
  { titulo: 'Comparação Shark vs LS2', href: '/comparacao-shark-vs-ls2/', imagem: '/images/Análise e Comparação Capacete Shark vs LS2 Scope.png', categoria: 'REVIEWS' },
  { titulo: 'Comparação Mixs vs Mormaii', href: '/comparacao-mixs-vs-mormaii/', imagem: '/images/Comparativo Capacete Mixs versos capacete mormaii .png', categoria: 'REVIEWS' },
  { titulo: 'Comparação MT vs Peels', href: '/comparacao-mt-vs-peels/', imagem: '/images/Análise e Comparação dos Capacete Peels Icon Fast vs Capacete  MT Stinger 2.png', categoria: 'REVIEWS' },

  { titulo: 'Capacete Bieffe B-Trail Review', href: '/capacete-bieffe-b-trail-review/', imagem: '/images/analise completa do Capacete Masculino Bieffe B-Trail Frontier Azul Oculos Moto.png', categoria: 'REVIEWS' },
  { titulo: 'HJC I90 vs AGV K1S', href: '/comparacao-agv-vs-hjc/', imagem: '/images/Comparação Capacete HJC I90 vs AGV K1S qual é o melhor .png', categoria: 'REVIEWS' },
  { titulo: 'Melhores Capacetes Anti-ruído', href: '/capacetes-anti-ruido/', imagem: '/images/melhor capacete de moto antiruido .png', categoria: 'DICAS' },
  { titulo: 'Comparação LS2 X Nolan', href: '/comparacao-ls2-x-nolan/', imagem: '/images/comparativo capacete LS2 versos capacte nolan.png', categoria: 'REVIEWS' },

  { titulo: 'Comparativo Taurus vs ProTork', href: '/comparativo-taurus-vs-protork/', imagem: '/images/comparativo capacete pro tork versos Taurus.png', categoria: 'REVIEWS' },
  { titulo: 'Comparativo Bieffe vs Norisk', href: '/comparativo-bieffe-vs-norisk/', imagem: '/images/comparativo cspscete bieffe versos norisk.png', categoria: 'REVIEWS' },
  { titulo: 'Jaqueta X11 Super Air: Vale a Pena?', href: '/jaqueta-x11-air-review/', imagem: '/images/Jaqueta Moto X11 Super Air .png', categoria: 'REVIEWS' },
  { titulo: 'Análise Jaqueta Texx', href: '/jaqueta-texx-motociclista-review/', imagem: '/images/melhorJaqueta texx para motociclista .png', categoria: 'REVIEWS' },

  { titulo: 'Melhores Jaquetas Alpinestars', href: '/jaquetas-alpinestars-review/', imagem: '/images/Melhores-Jaquetas-Alpinestars-cover.png', categoria: 'DICAS' },
  { titulo: 'X11 Crossover Adventure', href: '/x11-crossover-adventure-review/', imagem: '/images/X11-Crossover-Adventure-cover.png', categoria: 'REVIEWS' },
  { titulo: 'Análise da Marca X11', href: '/analise-da-marca-x11/', imagem: '/images/melhores-capacete-x11-cover.png', categoria: 'REVIEWS' },
  { titulo: 'Melhores Capacetes Adventure', href: '/capacete-adventure/', imagem: '/images/Melhores-Capacetes-Adventure-cover.png', categoria: 'DICAS' },

  { titulo: 'Capacete Peels Freeway Feminino', href: '/capacete-peels-freeway-review/', imagem: '/images/Peels-Freeway-cover.png', categoria: 'REVIEWS' },
  { titulo: 'Peels Icon Fast: Vale a Pena?', href: '/peels-icon-fast-review/', imagem: '/images/Peels-Icon-Fast-cover.png', categoria: 'REVIEWS' },
  { titulo: 'Capacete R8 Pro Tork', href: '/capacete-r8-protork-review/', imagem: '/images/ProTork-R8-cover.png', categoria: 'REVIEWS' },
  { titulo: 'Melhor Capacete para Bike', href: '/melhor-capacete-para-bike/', imagem: '/images/Melhores Capacetes de Ciclismo.png', categoria: 'DICAS' },

  { titulo: 'Melhor Capacete para Skate', href: '/melhor-capacete-para-skate/', imagem: '/images/Melhores capacete para andar de skate.png', categoria: 'DICAS' },
  { titulo: 'LS2 Scope Monocolor Review', href: '/ls2-scope-monocolor-review/', imagem: '/images/viseira-LS2-Scope-Monocolor-Titanium-Fosco.png', categoria: 'REVIEWS' },
  { titulo: 'Axxis Draken Review', href: '/axxis-draken-review/', imagem: '/images/capacete-axxis-draker-1.png', categoria: 'REVIEWS' },
  { titulo: 'HJC I90 Hollen Review', href: '/reveiw-hjc-i90-hollen/', imagem: '/images/Capacete-Hjc-I90-Davan-Preto-E-Verde-61.png', categoria: 'REVIEWS' },

  { titulo: 'AGV K1S Review', href: '/review-agv-k1/', imagem: '/images/Capacete-AGV-K1s.png', categoria: 'REVIEWS' },
  { titulo: 'Melhores Jaquetas Motociclistas', href: '/dica-melhor-jaqueta-motociclistas/', imagem: '/images/Como Escolher a Melhor Jaqueta de Moto .png', categoria: 'DICAS' },
  { titulo: 'Capacetes Custo-Benefício', href: '/custo-beneficio/', imagem: '/images/moto-shop-cover.png', categoria: 'DICAS' },
  { titulo: 'Melhores Capacetes 2026', href: '/melhor-capacete/', imagem: '/images/capacete moto -shark-preto.png', categoria: 'DICAS' },

  { titulo: 'Como Escolher Capacete', href: '/guia-definitivo/', imagem: '/images/moto-shop-cover.png', categoria: 'DICAS' },
  { titulo: 'Capacete Permitido na Pilotagem', href: '/capacete-permitido-na-pilotagem/', imagem: '/images/moto-shop-cover.png', categoria: 'DICAS' },
  { titulo: 'Capacete Astone Review', href: '/capacete-astone-review/', imagem: '/images/moto-shop-cover.png', categoria: 'REVIEWS' },
  { titulo: 'ProTork Evolution G8 Review', href: '/protork-evolution-g8-review/', imagem: '/images/moto-shop-cover.png', categoria: 'REVIEWS' }
];
---

<Layout title={title} description={description}>
  <Header />
  
  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <h1>Encontre os melhores capacetes para pilotar com estilo</h1>
        <p class="hero-subtitle">Nosso guia traz análises detalhadas dos modelos mais confiáveis.</p>
      </div>
    </section>

    <!-- Na Mídia Section -->
    <section class="na-midia-section">
      <div class="container">
        <h2>Na mídia</h2>
        <div class="na-midia-logos">
          <img src="/images/empresas e negocios.png" alt="Pequenas Empresas & Grandes Negócios" />
          <img src="/images/o globo.png" alt="O Globo" />
          <img src="/images/vocesa.png" alt="Você S/A" />
          <img src="/images/Terra.png" alt="Terra" />
        </div>
      </div>
    </section>

    <!-- Reviews dos Melhores Capacetes -->
    <section class="reviews-section">
      <div class="container">
        <h2>Reviews dos Melhores Capacetes de 2026</h2>
        <div class="reviews-grid">
          {reviewsCapacetes.map(review => (
            <a href={review.href} class="review-card">
              <div class="review-image">
                <img src={review.image} alt={review.name} loading="lazy" />
              </div>
              <h3>{review.name} é bom? Análise Completa</h3>
              <span class="read-more">Ler review →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Marcas Mais Vendidas -->
    <section class="marcas-venda-section">
      <div class="container">
        <h2>Reviews dos Melhores Capacetes de 2026</h2>
        <div class="marcas-container">
          {marcasVendidas.map(marca => (
            <div class="marca-full-card">
              <div class="marca-header-table">
                <div class="table-cell image-cell">
                  <img src={marca.imagem} alt={marca.nome} loading="lazy" />
                </div>
                <div class="table-cell title-cell">
                  <h3>{marca.nome}</h3>
                </div>
                <div class="table-cell action-cell">
                  <a href={marca.linkAfiliado} target="_blank" rel="nofollow noopener" class="btn-ir-loja">IR A LOJA</a>
                </div>
              </div>
              
              <div class="marca-pros-cons">
                <div class="pros">
                  <h4>Prós</h4>
                  <ul>
                    {marca.pros.map(pro => (
                      <li>{pro}</li>
                    ))}
                  </ul>
                </div>
                <div class="contras">
                  <h4>Contras</h4>
                  <ul>
                    {marca.contras.map(contra => (
                      <li>{contra}</li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Quem Sou -->
    <section class="quem-sou-section">
      <div class="container">
        <div class="quem-sou-card">
          <div class="quem-sou-image-wrapper">
            <div class="profile-frame">
              <img src="/images/mulher em sua moto com um capacete preto.png" alt="Pamela Pan" loading="lazy" />
            </div>
            <p class="profile-name">Pamela Pan</p>
          </div>
          <div class="quem-sou-content-box">
            <h2>Quem Sou</h2>
            <p>
              Olá, sou Pamela Pan, enfim, apaixonada por motos e tudo que as envolve! 
              Desde que pisei na minha primeira moto, fui cativado pela liberdade e pela 
              adrenalina que a pilotagem proporciona. Com o tempo, desenvolvi um amor especial por 
              capacetes e sua importância na segurança dos motociclistas. Neste blog, 
              compartilho minhas experiências e avaliações dos melhores capacetes do mercado, 
              sempre buscando ajudar outros motociclistas a fazer escolhas seguras e estilosas. 
              Sinta-se em casa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Capacete Aberto ou Fechado -->
    <section class="guia-section">
      <div class="container">
        <h2>Capacete aberto ou fechado, qual o melhor?</h2>
        <p class="guia-texto">
          A escolha do capacete ideal é uma decisão crucial para qualquer motociclista, ciclista ou praticante de esportes radicais. A segurança deve sempre vir em primeiro lugar, a escolha de um bom capacete pode fazer a diferença entre uma experiência emocionante e um acidente potencialmente grave. Neste blog, vamos explorar as melhores marcas disponíveis no mercado, levando em consideração não apenas a proteção, mas também o conforto, o estilo e a tecnologia envolvida.
        </p>
      </div>
    </section>

    <!-- Categorias de Capacetes -->
    <section class="categorias-section">
      <div class="container">
        <h2>Capacetes por Categoria</h2>
        <div class="categorias-grid">
          {categoriasCapacetes.map(cat => (
            <a 
              href={cat.href} 
              class="categoria-card" 
              target={cat.external ? "_blank" : undefined}
              rel={cat.external ? "nofollow noopener" : undefined}
            >
              <h3>{cat.nome}</h3>
              <div class="categoria-icon">
                <img src={cat.imagem} alt={cat.nome} loading="lazy" />
              </div>
              <span class="ver-modelos">Ver Modelos</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Posts Mais Vistos -->
    <section class="posts-populares-section">
      <div class="container">
        <h2>Posts mais vistos</h2>
        <div class="posts-grid" id="posts-grid">
          {postsMaisVistos.map((post, idx) => (
            <div class="post-card" data-page={Math.floor(idx / 4) + 1} style={idx < 4 ? '' : 'display:none;'}>
              <div class="post-image">
                <img src={post.imagem} alt={post.titulo} loading="lazy" />
                <span class="category-badge">{post.categoria}</span>
              </div>
              <div class="post-content">
                <h3>{post.titulo}</h3>
                <a href={post.href} class="leia-mais-link">LEIA MAIS &gt;</a>
              </div>
            </div>
          ))}
        </div>

        <nav class="pagination" id="posts-pagination" aria-label="Paginação"></nav>

        <script is:inline>
          (function() {
            const PER_PAGE = 4;
            let currentPage = 1;
            const cards = document.querySelectorAll('#posts-grid .post-card');
            const totalPages = Math.ceil(cards.length / PER_PAGE);
            const paginationEl = document.getElementById('posts-pagination');
            if (!paginationEl || cards.length === 0) return;

            function showPage(page) {
              currentPage = page;
              const start = (page - 1) * PER_PAGE;
              const end = start + PER_PAGE;
              cards.forEach((card, i) => {
                card.style.display = (i >= start && i < end) ? '' : 'none';
              });
              renderPagination();
              const section = document.querySelector('.posts-populares-section');
              if (section) section.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }

            function renderPagination() {
              let html = '';
              if (currentPage > 1) {
                html += '<a href="#" class="pg-btn pg-arrow" data-page="' + (currentPage - 1) + '">‹ Anterior</a>';
              }
              for (let i = 1; i <= totalPages; i++) {
                if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
                  html += '<a href="#" class="pg-btn' + (i === currentPage ? ' pg-active' : '') + '" data-page="' + i + '">' + i + '</a>';
                } else if (i === currentPage - 2 || i === currentPage + 2) {
                  html += '<span class="pg-dots">…</span>';
                }
              }
              if (currentPage < totalPages) {
                html += '<a href="#" class="pg-btn pg-arrow" data-page="' + (currentPage + 1) + '">Proxímo ›</a>';
              }
              paginationEl.innerHTML = html;
              paginationEl.querySelectorAll('.pg-btn').forEach(btn => {
                btn.addEventListener('click', function(e) {
                  e.preventDefault();
                  showPage(parseInt(this.dataset.page, 10));
                });
              });
            }

            showPage(1);
          })();
        </script>
      </div>
    </section>

    <!-- Sobre o Blog -->
    <section class="sobre-blog-section">
      <div class="container">
        <details class="sobre-details">
          <summary class="sobre-summary">
            <span class="toggle-icon">+</span>
            <span class="toggle-text">Saiba Mais</span>
          </summary>
          <div class="sobre-content">
            <p>
              Se você está em busca de informações confiáveis e detalhadas sobre capacetes 
              <a href="/custo-beneficio/">custo-benefício</a>, você está no lugar certo! Aqui, 
              nossa missão é fornecer a você análises aprofundadas e imparciais dos melhores 
              capacetes disponíveis no mercado.
            </p>
            <p>
              Sabemos que escolher o capacete ideal pode ser uma tarefa desafiadora, 
              especialmente com a diversidade de modelos e marcas disponíveis. Estamos aqui 
              para tornar essa decisão mais fácil e informada.
            </p>
            <p>
              Os capacetes desempenham um papel crucial na segurança de ciclistas, 
              motociclistas e praticantes de esportes radicais. Seja você um piloto experiente, 
              um ciclista casual ou alguém que simplesmente aprecia a adrenalina, a proteção da 
              sua cabeça deve sempre ser uma prioridade.
            </p>
            <p>
              Nós acreditamos que, além da segurança, o conforto e o estilo também são 
              fundamentais na escolha de um capacete. Em nosso blog, abordaremos não apenas 
              a segurança, mas também o conforto, o design e a durabilidade dos capacetes que 
              revisarmos.
            </p>
            <p>
              Nossas análises são feitas com base em testes práticos e pesquisas completas, 
              garantindo que você receba informações precisas e atualizadas. Avaliamos diversos 
              aspectos dos capacetes, incluindo materiais utilizados, sistemas de ventilação, 
              peso, ajuste e facilidade de limpeza.
            </p>
            <p>
              Você encontrará categorias específicas que ajudam a navegar pelo nosso conteúdo. 
              Temos seções dedicadas a capacetes para motocicletas, bicicletas, skate e outros 
              esportes, facilitando a busca pelo capacete que melhor se adapta às suas necessidades.
            </p>
            <p>
              Se você está buscando dicas para a escolha do capacete perfeito, também temos 
              uma seção de guias onde compartilhamos informações valiosas sobre como avaliar e 
              selecionar o capacete ideal para você.
            </p>
            <p>
              Além dos reviews e guias, nossa intenção é criar uma comunidade acolhedora e 
              engajada. Queremos que você compartilhe suas experiências e opiniões sobre os 
              capacetes que já testou. Seu feedback é fundamental para que outros leitores 
              possam tomar decisões informadas.
            </p>
            <p>
              Estamos abertos a comentários e sugestões, criando um espaço onde todos possam 
              aprender e trocar informações sobre segurança e conforto.
            </p>
            <p>
              Manter-se atualizado sobre as últimas novidades do mercado de capacetes é essencial. 
              Por isso, estaremos sempre compartilhando informações sobre tendências, lançamentos 
              e inovações tecnológicas que podem impactar sua escolha.
            </p>
            <p>
              Nossos leitores são nossa prioridade, e estamos comprometidos em proporcionar 
              conteúdo de qualidade que atenda às suas expectativas.
            </p>
            <p>
              Agradecemos sua visita ao nosso blog e esperamos que você encontre informações 
              úteis e inspiradoras. Navegue por nossas avaliações, descubra novos capacetes e, 
              acima de tudo, priorize sua segurança. O equipamento certo pode fazer toda a 
              diferença, seja ele <a href="/capacetes-feminino/">capacete feminino</a> ou 
              masculino, estamos aqui para ajudá-lo nessa jornada.
            </p>
          </div>
        </details>
      </div>
    </section>

    <script>
      const details = document.querySelector('.sobre-details') as HTMLDetailsElement;
      const toggleText = document.querySelector('.toggle-text');
      const toggleIcon = document.querySelector('.toggle-icon');

      details?.addEventListener('toggle', () => {
        if (details.open) {
          if (toggleText) toggleText.textContent = 'Fechar';
          if (toggleIcon) toggleIcon.textContent = '-';
        } else {
          if (toggleText) toggleText.textContent = 'Saiba Mais';
          if (toggleIcon) toggleIcon.textContent = '+';
        }
      });
    </script>
  </main>
  
  <Footer showSocial={false} />
</Layout>
