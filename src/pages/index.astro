---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { allReviews } from '../data/reviews';

const title = 'Encontre os melhores capacetes para pilotar com estilo';
const description = 'Nosso guia traz análises detalhadas dos modelos mais confiáveis.';

const featuredHrefs = [
  '/peels-icon-fast-review/',
  '/comparacao-shark-vs-ls2/',
  '/capacete-bieffe-b-trail-review/',
  '/comparativo-bieffe-vs-norisk/',
  '/analise-da-marca-x11/',
  '/capacete-peels-freeway-review/'
];

const reviewsCapacetes = featuredHrefs
  .map(href => allReviews.find(r => r.href === href))
  .filter((r): r is typeof allReviews[number] => Boolean(r))
  .map(r => ({
    name: r.title,
    href: r.href,
    image: r.image
  }));

const marcasVendidas = [
  {
    nome: 'Capacete Arai Corsair X - Hayden Laguna',
    imagem: '/images/Capacete-arai.png',
    linkAfiliado: 'https://amzn.to/42Ejkbt',
    pros: [
      'Conforto Superior para Longas Jornadas - Interior de nylon escovado premium, removível e lavável',
      'Ventilação Eficiente e Silenciosa - 12 pontos de ventilação (7 entradas e 5 saídas)',
      'Segurança Avançada - Certificação ECE R22-06, Sistema de Contorno Facial (FCS) e Sistema de Abertura de Emergência (ERS)'
    ],
