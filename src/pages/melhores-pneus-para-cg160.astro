---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Melhores Pneus para CG 160: Guia Completo 2026';
const description = 'Confira os melhores pneus para Honda CG 160 em 2026. Modelos, marcas, preços e qual escolher para uso urbano, viagens e motofrete.';
const canonical = 'https://jovemapan.com.br/melhores-pneus-para-cg160/';
const author = 'Marcelo Ferreira';
const authorImage = '/images/marcelo-ferreira.png';
const publishDate = '2026-04-23';
const category = 'Guias';
const categoryHref = '/category/reviews/';
const coverImage = '/images/moto-shop-cover.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. Medidas originais da CG 160', href: '#medidas' },
  { label: '3. Top pneus recomendados', href: '#top-pneus' },
  { label: '4. Como escolher pelo uso', href: '#como-escolher' },
  { label: '5. Conclusão', href: '#conclusao' },
];

const tags = [
  { label: 'GUIA', href: '#' },
  { label: 'CG 160', href: '#' },
  { label: 'PNEUS', href: '#' },
  { label: '2026', href: '#' },
];

const featuredProduct = {
  preTitle: 'APROVEITE FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete Shoei Premium Edition',
  name: 'Capacete Shoei<br/>Premium Edition',
  mercadoLivreHref: '#',
  amazonHref: '#',
};

const authorBio = {
  name: author,
  description: 'Redator & Editor especializado em transformar especificações técnicas complexas em conteúdo claro, envolvente e acessível.',
  image: authorImage,
  profileHref: '/author-marcelo-ferreira/',
  profileLabel: 'Ver perfil completo ›',
};
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  authorImage={authorImage}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  featuredProduct={featuredProduct}
>
  <p class="post-lead" id="introducao">
    Conteúdo do post em breve.
  </p>

  <h2 id="medidas">Medidas originais da CG 160</h2>
  <p>Em breve.</p>

  <h2 id="top-pneus">Top pneus recomendados</h2>
  <p>Em breve.</p>

  <h2 id="como-escolher">Como escolher pelo uso</h2>
  <p>Em breve.</p>

  <h2 id="conclusao">Conclusão</h2>
  <p>Em breve.</p>
</PostLayout>
