---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  views={views}
  comments={comments}
  indice={indice}
  tags={tags}
