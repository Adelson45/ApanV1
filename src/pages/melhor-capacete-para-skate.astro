const category    = 'DICAS';
const categoryHref = '/category/dicas/';
const coverImage  = '/images/Melhores capacete para andar de skate.png';

const views       = '12K VIEWS';
const comments    = '8 COMMENTS';

const indice = [
  { label: '1. A importância do capacete para skate', href: '#importancia' },
  { label: '2. Escolhas populares entre profissionais', href: '#profissionais' },
  { label: '3. Considerando seu estilo pessoal', href: '#estilo' },
  { label: '4. Top 10 melhores capacetes', href: '#top10' },
  { label: '5. Características do melhor capacete', href: '#caracteristicas' },
  { label: '6. Manutenção e cuidados', href: '#manutencao' },
  { label: '7. Perguntas Frequentes', href: '#faq' },
  { label: '8. Conclusão', href: '#conclusao' }
];

const tags = [
  { label: 'DICAS', href: '/category/dicas/' },
  { label: 'SKATE', href: '#' },
  { label: 'CAPACETE SKATE', href: '#' },
  { label: 'SEGURANÇA', href: '#' },
  { label: '2026', href: '#' }
];

const authorBio = {
  name: 'Pamela Pan',
  description: 'Cofundadora e Editora-chefe do Blog Apan, especializada em trazer as melhores análises e tendências do mundo das duas rodas.',
  image: '/images/Pamela pan coufundadora e editoara chefe do blog apan .png',
  profileHref: '/author-pamela-pan/',
  profileLabel: 'Ver perfil completo ›'
};

const featuredProduct = {
  preTitle: 'DESTAQUE 2026',
  image: '/images/Capacete de Skate Triple Eight Sweatsaver.png',
  imageAlt: 'Capacete em Destaque',
  name: 'Triple Eight Sweatsaver',
  amazonHref: 'https://amzn.to/3UHsgtb',
  mercadoLivreHref: 'https://mercadolivre.com/sec/1ZXGMm9'
