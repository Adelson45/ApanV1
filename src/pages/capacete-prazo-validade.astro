---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Capacete Tem Prazo de Validade? Entenda a Vida Útil do Seu Equipamento';
const description = 'Descubra o prazo de validade do capacete de moto, por que ele existe, como identificar o vencimento e quando é hora de trocar para não comprometer a segurança.';
const canonical = 'https://jovemapan.com.br/capacete-prazo-validade/';
const author = 'Marcelo Ferreira';
const authorImage = '/images/marcelo-ferreira.png';
const publishDate = '2026-04-23';
const category = 'Segurança';
const categoryHref = '/melhor-capacete/';
const coverImage = '/images/moto-shop-cover.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. Por que o capacete tem validade', href: '#por-que' },
  { label: '3. Quanto tempo dura', href: '#tempo' },
  { label: '4. Como identificar a data de fabricação', href: '#data-fabricacao' },
  { label: '5. Conclusão', href: '#conclusao' },
];

const tags = [
  { label: 'VALIDADE', href: '#' },
  { label: 'SEGURANÇA', href: '#' },
  { label: 'CAPACETE', href: '/melhor-capacete/' },
  { label: '2026', href: '#' },
];

const featuredProduct = {
  preTitle: 'APROVEITE FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete Shoei Premium Edition',
  name: 'Capacete Shoei<br/>Premium Edition',
  mercadoLivreHref: '#',
  amazonHref: '#',
};

const authorBio = {
  name: author,
  description: 'Redator & Editor especializado em transformar especificações técnicas complexas em conteúdo claro, envolvente e acessível.',
  image: authorImage,
  profileHref: '/author-marcelo-ferreira/',
  profileLabel: 'Ver perfil completo ›',
};
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  authorImage={authorImage}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  featuredProduct={featuredProduct}
>
  <p class="post-lead" id="introducao">
    Conteúdo do post em breve.
  </p>

  <h2 id="por-que">Por que o capacete tem validade</h2>
  <p>Em breve.</p>

  <h2 id="tempo">Quanto tempo dura</h2>
  <p>Em breve.</p>

  <h2 id="data-fabricacao">Como identificar a data de fabricação</h2>
  <p>Em breve.</p>

  <h2 id="conclusao">Conclusão</h2>
  <p>Em breve.</p>
</PostLayout>
