  { label: '4. Recomendações práticas', href: '#recomendacoes' },
  { label: '5. Capacete quebrado e multas', href: '#capacete-quebrado' },
  { label: '6. Polícia pode multar?', href: '#policia' },
  { label: '7. Frequência de lavagem', href: '#lavagem' },
  { label: '8. Produtos a evitar', href: '#produtos-evitar' },
  { label: '9. Conclusão', href: '#conclusao' },
  { label: '10. Perguntas Frequentes', href: '#faq' },
];

const tags = [
  { label: 'VALIDADE', href: '#' },
  { label: 'SEGURANÇA', href: '#' },
  { label: 'CAPACETE', href: '/melhor-capacete/' },
  { label: 'INMETRO', href: '#' },
  { label: '2026', href: '#' },
];

const featuredProduct = {
  preTitle: 'APROVEITE FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete Shoei Premium Edition',
  name: 'Capacete Shoei<br/>Premium Edition',
  mercadoLivreHref: '#',
  amazonHref: '#',
};

