---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Qual Prazo de Validade do Capacete de Moto? Entenda!';
const description = 'Descubra o prazo de validade do capacete de moto, por que ele existe, como identificar o vencimento e quando é hora de trocar para não comprometer a segurança.';
const canonical = 'https://jovemapan.com.br/capacete-prazo-validade/';
const author = 'Pamela Pan';
const authorImage = '/images/Pamela%20pan%20coufundadora%20e%20editoara%20chefe%20do%20blog%20apan%20.png';
const publishDate = '2025-07-01';
const category = 'Segurança';
const categoryHref = '/melhor-capacete/';
const coverImage = '/images/quais-os-prazos-de-validade-deum-capacete-de-moto-descruba-a-importancia.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. Por que a conservação é importante', href: '#conservacao' },
