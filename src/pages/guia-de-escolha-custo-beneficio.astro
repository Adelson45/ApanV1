---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Guia de Escolha: Capacete Custo-Benefício 2026';
const description = 'Descubra como escolher o capacete com o melhor custo-benefício do mercado. Critérios, certificações, materiais e dicas práticas para acertar na compra.';
const canonical = 'https://jovemapan.com.br/guia-de-escolha-custo-beneficio/';
const author = 'Marcelo Ferreira';
const authorImage = '/images/marcelo-ferreira.png';
const publishDate = '2026-04-23';
const category = 'Guias';
const categoryHref = '/custo-beneficio/';
const coverImage = '/images/moto-shop-cover.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. O que é custo-benefício de verdade', href: '#custo-beneficio' },
  { label: '3. Critérios de escolha', href: '#criterios' },
  { label: '4. Erros comuns na compra', href: '#erros' },
  { label: '5. Conclusão', href: '#conclusao' },
];

const tags = [
  { label: 'GUIA', href: '#' },
  { label: 'CAPACETES', href: '/melhor-capacete/' },
  { label: 'CUSTO-BENEFÍCIO', href: '/custo-beneficio/' },
  { label: '2026', href: '#' },
];

const featuredProduct = {
  preTitle: 'APROVEITE FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete Shoei Premium Edition',
  name: 'Capacete Shoei<br/>Premium Edition',
  mercadoLivreHref: '#',
  amazonHref: '#',
};

const authorBio = {
  name: author,
  description: 'Redator & Editor especializado em transformar especificações técnicas complexas em conteúdo claro, envolvente e acessível.',
  image: authorImage,
  profileHref: '/author-marcelo-ferreira/',
  profileLabel: 'Ver perfil completo ›',
};
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  authorImage={authorImage}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  featuredProduct={featuredProduct}
>
  <p class="post-lead" id="introducao">
    Conteúdo do post em breve.
  </p>

  <h2 id="custo-beneficio">O que é custo-benefício de verdade</h2>
  <p>Em breve.</p>

  <h2 id="criterios">Critérios de escolha</h2>
  <p>Em breve.</p>

  <h2 id="erros">Erros comuns na compra</h2>
  <p>Em breve.</p>

  <h2 id="conclusao">Conclusão</h2>
  <p>Em breve.</p>
</PostLayout>
