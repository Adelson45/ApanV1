---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Jaquetas Alpinestars Review: Os Melhores Modelos de 2026';
const description = 'Review completo das jaquetas Alpinestars em 2026. Tecnologias, proteções, modelos top e se vale o investimento premium para o motociclista.';
const canonical = 'https://jovemapan.com.br/jaquetas-alpinestars-review/';
const author = 'Marcelo Ferreira';
const authorImage = '/images/marcelo-ferreira.png';
const publishDate = '2026-04-23';
const category = 'Reviews';
const categoryHref = '/dica-melhor-jaqueta-motociclistas/';
const coverImage = '/images/moto-shop-cover.png';

const indice = [
  { label: '1. Introdução', href: '#introducao' },
  { label: '2. Sobre a marca Alpinestars', href: '#marca' },
  { label: '3. Top modelos', href: '#modelos' },
  { label: '4. Prós e contras', href: '#pros-contras' },
  { label: '5. Conclusão', href: '#conclusao' },
];

const tags = [
  { label: 'REVIEW', href: '#' },
  { label: 'ALPINESTARS', href: '#' },
  { label: 'JAQUETAS', href: '/dica-melhor-jaqueta-motociclistas/' },
  { label: '2026', href: '#' },
];

const featuredProduct = {
  preTitle: 'APROVEITE FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete Shoei Premium Edition',
  name: 'Capacete Shoei<br/>Premium Edition',
  mercadoLivreHref: '#',
  amazonHref: '#',
};

const authorBio = {
  name: author,
  description: 'Redator & Editor especializado em transformar especificações técnicas complexas em conteúdo claro, envolvente e acessível.',
  image: authorImage,
  profileHref: '/author-marcelo-ferreira/',
  profileLabel: 'Ver perfil completo ›',
};
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  authorImage={authorImage}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  featuredProduct={featuredProduct}
>
  <p class="post-lead" id="introducao">Conteúdo do post em breve.</p>
  <h2 id="marca">Sobre a marca Alpinestars</h2>
  <p>Em breve.</p>
  <h2 id="modelos">Top modelos</h2>
  <p>Em breve.</p>
  <h2 id="pros-contras">Prós e contras</h2>
  <p>Em breve.</p>
  <h2 id="conclusao">Conclusão</h2>
  <p>Em breve.</p>
</PostLayout>
