---
import PostLayout from '../layouts/PostLayout.astro';

const title = 'Melhores Cadeados para Moto 2026 | Anti-Furto e Segurança';
const description = 'Descubra os melhores cadeados para moto de 2026. Análises de cadeados disco, corrente e trava de guidão. Proteja sua motocicleta contra roubos.';
const canonical   = 'https://jovemapan.com.br/cadeados-para-moto/';
const author      = 'Paula Becker';
const authorImage = '/images/Ana paula editora do blog apan .png';
const publishDate = '20 ABR, 2026';
const category    = 'ACESSÓRIOS';
const categoryHref = '/acessorios/';
const coverImage  = '/images/cadeado-disco-xena.jpg';
const views       = '32K VIEWS';
const comments    = '8 COMMENTS';

const indice = [
  { label: 'Introdução: Segurança Anti-Furto', href: '#introducao' },
  { label: 'Tipos de Cadeados para Moto', href: '#tipos' },
  { label: 'Top 4 Melhores Cadeados 2026', href: '#top4' },
  { label: 'Comparativo: Qual Escolher?', href: '#comparativo' },
  { label: 'Dicas de Segurança Essenciais', href: '#dicas' },
  { label: 'Conclusão e Recomendações', href: '#conclusao' }
];

const tags = [
  { label: 'REVIEW', href: '#' },
  { label: 'SEGURANÇA', href: '#' },
  { label: 'CADEADOS', href: '#' }
];

const authorBio = {
  name: 'Paula Becker',
  description: 'Redatora especialista em acessórios automotivos e dicas de segurança para motociclistas.',
  image: '/images/Ana paula editora do blog apan .png',
  profileHref: '/author-paula-becker/',
  profileLabel: 'Ver perfil completo ›'
};

const featuredProduct = {
  preTitle: 'FRETE GRÁTIS',
  image: '/images/capacete-shoei.png',
  imageAlt: 'Capacete em Destaque',
  name: 'Capacete Shoei X-Spirit 3',
  amazonHref: 'https://amzn.to/4vEOj4K',
  mercadoLivreHref: '/melhor-capacete/'
};
---

<PostLayout
  title={title}
  description={description}
  canonical={canonical}
  author={author}
  authorImage={authorImage}
  publishDate={publishDate}
  category={category}
  categoryHref={categoryHref}
  coverImage={coverImage}
  views={views}
  comments={comments}
  indice={indice}
  tags={tags}
  authorBio={authorBio}
  featuredProduct={featuredProduct}
>

<!-- CONTEÚDO DE EXEMPLO -->
          
          <h2 id="introducao">Melhores Cadeados para Moto em 2026</h2>
          <p>
            <strong>Conteúdo de exemplo</strong> - Lorem ipsum dolor sit amet, consectetur adipiscing elit. 
            Este é um texto placeholder que será substituído pelo conteúdo original da página sobre cadeados para moto.
          </p>
          <p>
            Aqui você pode adicionar a introdução completa com todas as análises dos melhores cadeados de 2026, 
            incluindo modelos de disco com alarme, correntes pesadas e travas de guidão.
          </p>

          <h2 id="tipos">Tipos de Cadeados para Moto</h2>
          <p>Conteúdo de exemplo sobre os diferentes tipos de cadeados disponíveis no mercado...</p>

          <h2 id="top4">Top 4 Melhores Cadeados 2026</h2>
          <p>Conteúdo de exemplo com os produtos recomendados...</p>

          <h2 id="comparativo">Comparativo</h2>
          <p>Tabela comparativa dos modelos...</p>

          <h2 id="dicas">Dicas de Segurança</h2>
          <p>Dicas práticas para proteger sua motocicleta...</p>

          <h2 id="conclusao">Conclusão</h2>
          <p>Resumo e recomendações finais...</p>




</PostLayout>
