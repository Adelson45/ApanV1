---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface IndiceItem {
  label: string;
  href: string;
  children?: { label: string; href: string }[];
}

interface Tag {
  label: string;
  href?: string;
}

interface FeaturedProduct {
  preTitle?: string;
  image?: string;
  imageAlt?: string;
  name?: string;
  mercadoLivreHref?: string;
  amazonHref?: string;
}

interface ExtraProduct {
  badge?: string;
  badgeStyle?: 'frete' | 'desconto';
  image?: string;
  imageAlt?: string;
  name?: string;
  mercadoLivreHref?: string;
  amazonHref?: string;
}

interface PopularItem {
  label: string;
  href: string;
}

interface AuthorBio {
  name?: string;
  description?: string;
  image?: string;
  profileHref?: string;
  profileLabel?: string;
}

interface Props {
  title: string;
  description: string;
  canonical?: string;
  coverImage?: string;
  coverImageAlt?: string;
  category?: string;
  categoryHref?: string;
  categoryLabel?: string;
  publishDate?: string;
  author?: string;
  authorImage?: string;
  authorHref?: string;
  views?: string;
  comments?: string;
  indice?: IndiceItem[];
  tags?: Tag[];
  featuredProduct?: FeaturedProduct;
  extraProducts?: ExtraProduct[];
  popular?: PopularItem[];
  authorBio?: AuthorBio;
  hideShare?: boolean;
  hideAuthor?: boolean;
  hideComments?: boolean;
}

const {
  title,
  description,
  canonical,
  coverImage = '',
  coverImageAlt,
  category = 'GERAL',
  categoryHref = '/',
  categoryLabel,
  publishDate = '',
  author = 'Jovem Apan',
  authorImage = '',
  authorHref = '#',
  views,
  comments,
  indice,
  tags,
  featuredProduct,
  extraProducts,
  popular,
  authorBio,
  hideShare = false,
  hideAuthor = false,
  hideComments = false,
} = Astro.props;

const pageUrl = canonical ?? `https://jovemapan.com.br${Astro.url.pathname}`;

const defaultPopular: PopularItem[] = [
  { label: 'Melhores Capacetes de Moto 2026', href: '/melhor-capacete/' },
  { label: 'Capacetes Custo Benefício', href: '/custo-beneficio/' },
  { label: 'Capacete Norisk Vale a Pena?', href: '/capacete-norisk-vale-a-pena/' },
  { label: 'Review LS2 Scope Monocolor', href: '/ls2-scope-monocolor-review/' },
  { label: 'Melhores Mochilas para Moto', href: '/mochila-para-moto/' },
];

const popularList = popular ?? defaultPopular;
const hasFeatured = !!featuredProduct;
const hasIndice = !!indice && indice.length > 0;
const hasTags = !!tags && tags.length > 0;
const hasAuthorBio = !!authorBio;
const displayCategory = categoryLabel ?? category;

const shareUrlEncoded = encodeURIComponent(pageUrl);
const shareTitleEncoded = encodeURIComponent(title);
---

<Layout title={title} description={description} canonical={pageUrl} ogImage={coverImage || undefined}>
  <Header />

  <main class="post-main">
    <div class="post-container">

      <!-- 1. CABEÇALHO (Breadcrumb, Categoria, Título, Meta) -->
      <div class="post-header-section">
        <nav class="top-breadcrumb" aria-label="Breadcrumb">
          <a href="/">HOME</a>
          <span class="separator">›</span>
          <a href={categoryHref}>{displayCategory}</a>
          <span class="separator">›</span>
          <span class="current-page">{title}</span>
        </nav>

        <a href={categoryHref} class="post-category-tag">
          <svg class="icon" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
          {displayCategory}
        </a>

        <h1 class="post-title">{title}</h1>

        <div class="post-meta-data">
          <div class="meta-author">
            {authorImage && (
              <img src={authorImage} alt={author} class="author-avatar" />
            )}
            <strong>{author.toUpperCase()}</strong>
          </div>
          <div class="meta-info">
            {publishDate && (
              <span class="meta-item">
                <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                {publishDate}
              </span>
            )}
            {views && (
              <span class="meta-item">
                <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                {views}
              </span>
            )}
            {comments && (
              <span class="meta-item">
                <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                {comments}
              </span>
            )}
          </div>
        </div>
      </div>

      <!-- 2. GRID PRINCIPAL -->
      <div class="post-layout-grid">

        <!-- [ESQUERDA] Botões Sociais -->
        <div class="post-social-col">
          <div class="sticky-socials">
            <a href="https://www.facebook.com/profile.php?id=100088166945491" target="_blank" rel="noopener noreferrer" class="social-btn facebook" aria-label="Facebook">f</a>
            <a href="https://br.pinterest.com/jovemapan/" target="_blank" rel="noopener noreferrer" class="social-btn pinterest" aria-label="Pinterest">
              <svg viewBox="0 0 24 24" fill="white" width="18" height="18"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
            </a>
            <a href="https://www.youtube.com/channel/UCChj9-uIY5ERfidZ6K-zt_w" target="_blank" rel="noopener noreferrer" class="social-btn youtube" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="white" width="18" height="18"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
            <a href="https://www.instagram.com/jovem_apan/" target="_blank" rel="noopener noreferrer" class="social-btn instagram" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" width="18" height="18"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
          </div>
        </div>

        <!-- [CENTRO] Artigo -->
        <article class="post-content-col">

          {coverImage && (
            <div class="post-cover-image">
              <img src={coverImage} alt={coverImageAlt ?? title} />
              <div class="verified-badge">
                <svg viewBox="0 0 24 24" width="12" height="12" stroke="var(--red)" stroke-width="3" fill="none"><polyline points="20 6 9 17 4 12"></polyline></svg>
                APAN VERIFIED
              </div>
            </div>
          )}

          {hasIndice && (
            <div class="post-indice" id="indice-accordion">
              <div class="indice-header" onclick="toggleIndice()">
                <div class="indice-left">
                  <div class="indice-icon">
                    <svg viewBox="0 0 24 24" width="18" height="18" stroke="white" stroke-width="2" fill="none"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
                  </div>
                  <strong>ÍNDICE DE CONTEÚDO</strong>
                </div>
                <div class="indice-arrow" id="indice-arrow">
                  <svg viewBox="0 0 24 24" width="16" height="16" stroke="var(--text-meta)" stroke-width="2" fill="none"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </div>
              </div>
              <div class="indice-content" id="indice-content">
                <ul class="indice-links">
                  {indice!.map((item) => (
                    <li>
                      <a href={item.href}>{item.label}</a>
                      {item.children && item.children.length > 0 && (
                        <ul>
                          {item.children.map((child) => (
                            <li><a href={child.href}>{child.label}</a></li>
                          ))}
                        </ul>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          )}

          <div class="post-content-body">
            <slot />
          </div>

          <!-- Footer do Post: Tags, Share, Bio -->
          <div class="post-footer">
            {hasTags && (
              <div class="post-tags-container">
                <strong>TAGS:</strong>
                <div class="post-tags">
                  {tags!.map((tag) => (
                    <a href={tag.href ?? '#'}>{tag.label}</a>
                  ))}
                </div>
              </div>
            )}

            {!hideShare && (
              <div class="webcreation-social-wrapper">
                <span class="hide-on-mobile">Compartilhar:</span>

                <a class="webcreation-social-sharing webcreation-social-facebook" href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrlEncoded}`} target="_blank" rel="nofollow noopener" aria-label="Compartilhar no Facebook">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24">
                    <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>
                  </svg>
                </a>

                <a class="webcreation-social-sharing webcreation-social-whatsapp" href={`https://api.whatsapp.com/send?text=${shareTitleEncoded}%20${shareUrlEncoded}`} target="_blank" rel="nofollow noopener" aria-label="Compartilhar no WhatsApp">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24">
                    <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
                  </svg>
                </a>

                <a class="webcreation-social-sharing webcreation-social-twitter" href={`https://twitter.com/intent/tweet?text=${shareTitleEncoded}&url=${shareUrlEncoded}`} target="_blank" rel="nofollow noopener" aria-label="Compartilhar no Twitter">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24">
                    <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
                  </svg>
                </a>

                <a class="webcreation-social-sharing webcreation-social-pinterest" href={`https://pinterest.com/pin/create/button/?url=${shareUrlEncoded}&description=${shareTitleEncoded}`} target="_blank" rel="nofollow noopener" aria-label="Compartilhar no Pinterest">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24">
                    <path d="M12 0c-6.627 0-12 5.372-12 12 0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146 1.124.347 2.317.535 3.554.535 6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z" fill-rule="evenodd" clip-rule="evenodd"/>
                  </svg>
                </a>

                <a class="webcreation-social-sharing webcreation-social-linkedin" href={`https://www.linkedin.com/shareArticle?mini=true&url=${shareUrlEncoded}&title=${shareTitleEncoded}`} target="_blank" rel="nofollow noopener" aria-label="Compartilhar no LinkedIn">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24">
                    <path d="M4.98 3.5c0 1.381-1.11 2.5-2.48 2.5s-2.48-1.119-2.48-2.5c0-1.38 1.11-2.5 2.48-2.5s2.48 1.12 2.48 2.5zm.02 4.5h-5v16h5v-16zm7.982 0h-4.968v16h4.969v-8.399c0-4.67 6.029-5.052 6.029 0v8.399h4.988v-10.131c0-7.88-8.922-7.593-11.018-3.714v-2.155z"/>
                  </svg>
                </a>

                <a class="webcreation-social-sharing webcreation-social-reddit" href={`https://www.reddit.com/submit?url=${shareUrlEncoded}&title=${shareTitleEncoded}`} target="_blank" rel="nofollow noopener" aria-label="Compartilhar no Reddit">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"><path d="M24 11.779c0-1.459-1.192-2.645-2.657-2.645-.715 0-1.363.286-1.84.746-1.81-1.191-4.259-1.949-6.971-2.046l1.483-4.669 4.016.941-.006.058c0 1.193.975 2.163 2.174 2.163 1.198 0 2.172-.97 2.172-2.163s-.975-2.164-2.172-2.164c-.92 0-1.704.574-2.021 1.379l-4.329-1.015c-.189-.046-.381.063-.44.249l-1.654 5.207c-2.838.034-5.409.798-7.3 2.025-.474-.438-1.103-.712-1.799-.712-1.465 0-2.656 1.187-2.656 2.646 0 .97.533 1.811 1.317 2.271-.052.282-.086.567-.086.857 0 3.911 4.808 7.093 10.719 7.093s10.72-3.182 10.72-7.093c0-.274-.029-.544-.075-.81.832-.447 1.405-1.312 1.405-2.318zm-17.224 1.816c0-.868.71-1.575 1.582-1.575.872 0 1.581.707 1.581 1.575s-.709 1.574-1.581 1.574-1.582-.706-1.582-1.574zm9.061 4.669c-.797.793-2.048 1.179-3.824 1.179l-.013-.003-.013.003c-1.777 0-3.028-.386-3.824-1.179-.145-.144-.145-.379 0-.523.145-.145.381-.145.526 0 .65.647 1.729.961 3.298.961l.013.003.013-.003c1.569 0 2.648-.315 3.298-.962.145-.145.381-.144.526 0 .145.145.145.379 0 .524zm-.189-3.095c-.872 0-1.581-.706-1.581-1.574 0-.868.709-1.575 1.581-1.575s1.581.707 1.581 1.575-.709 1.574-1.581 1.574z"/></svg>
                </a>
              </div>
            )}

            {!hideAuthor && hasAuthorBio && (
              <div class="author-bio-box">
                <div class="bio-avatar">
                  <img
                    src={authorBio!.image ?? authorImage ?? `https://ui-avatars.com/api/?name=${encodeURIComponent(authorBio!.name ?? author)}&background=random`}
                    alt={authorBio!.name ?? author}
                  />
                </div>
                <div class="bio-content">
                  <span class="bio-label">SOBRE O AUTOR</span>
                  <h4 class="bio-name">{authorBio!.name ?? author}</h4>
                  {authorBio!.description && (
                    <p class="bio-desc">{authorBio!.description}</p>
                  )}
                  <a class="bio-link" href={authorBio!.profileHref ?? authorHref}>
                    {authorBio!.profileLabel ?? 'Ver perfil completo ›'}
                  </a>
                </div>
              </div>
            )}
          </div>

          <!-- Comentários -->
          {!hideComments && (
            <div class="post-comments-section">
              <h3 class="comments-title">DEIXE UM COMENTÁRIO</h3>
              <p class="comments-note">Seu e-mail não será publicado. Campos obrigatórios estão marcados com *</p>

              <form class="comments-form" action="javascript:void(0)" method="POST">
                <div class="form-group full-width">
                  <textarea placeholder="Escreva seu comentário aqui... *" required rows="6"></textarea>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <input type="text" placeholder="Seu nome *" required />
                  </div>
                  <div class="form-group">
                    <input type="email" placeholder="Seu e-mail *" required />
                  </div>
                </div>
                <button type="submit" class="btn-submit-comment">POSTAR COMENTÁRIO</button>
              </form>
            </div>
          )}

        </article>

        <!-- [DIREITA] Sidebar -->
        <aside class="post-sidebar-col">

          {hasFeatured && (
            <div class="sidebar-widget produto-destaque">
              {featuredProduct!.preTitle && (
                <p class="frete-gratis">{featuredProduct!.preTitle}</p>
              )}
              {featuredProduct!.image && (
                <img
                  src={featuredProduct!.image}
                  alt={featuredProduct!.imageAlt ?? featuredProduct!.name ?? 'Produto em destaque'}
                  class="produto-imagem"
                />
              )}
              {featuredProduct!.name && (
                <h4 class="produto-nome" set:html={featuredProduct!.name} />
              )}
              {featuredProduct!.mercadoLivreHref && (
                <a href={featuredProduct!.mercadoLivreHref} target="_blank" rel="noopener noreferrer nofollow" class="btn-produto-destaque ml">
                  VER NO MERCADO LIVRE
                </a>
              )}
              {featuredProduct!.amazonHref && (
                <a href={featuredProduct!.amazonHref} target="_blank" rel="noopener noreferrer nofollow" class="btn-produto-destaque amazon">
                  VER OFERTA NA AMAZON
                </a>
              )}
            </div>
          )}

          {extraProducts && extraProducts.map((p) => (
            <div class="sidebar-widget produto-widget-extra">
              {p.badge && (
                <p class={`widget-badge-extra ${p.badgeStyle === 'desconto' ? 'desconto' : 'frete'}`}>{p.badge}</p>
              )}
              {p.image && (
                <img src={p.image} alt={p.imageAlt ?? p.name ?? 'Produto'} class="widget-img-extra" />
              )}
              {p.name && <h4 class="widget-name-extra">{p.name}</h4>}
              <div class="widget-links-extra">
                {p.mercadoLivreHref && (
                  <a href={p.mercadoLivreHref} target="_blank" rel="noopener noreferrer nofollow" class="btn-widget-extra">VER NO MERCADO LIVRE</a>
                )}
                {p.amazonHref && (
                  <a href={p.amazonHref} target="_blank" rel="noopener noreferrer nofollow" class="btn-widget-extra">VER NA AMAZON</a>
                )}
              </div>
            </div>
          ))}

          <div class="sidebar-widget newsletter-vip">
            <div class="newsletter-icon">
              <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="1.5" fill="none"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
